---
import type { ComunidadResumen, ComunidadTipo } from '../lib/sanity';
import { t, type Lang } from '../lib/i18n';

interface Props {
  comunidades: ComunidadResumen[];
  comunidadDestacada?: string;
  lang?: Lang;
  basePath?: string;
}

const {
  comunidades,
  comunidadDestacada,
  lang = 'es',
  basePath = '',
} = Astro.props;

const destacada = comunidadDestacada
  ? comunidades.find((c) => c.slug === comunidadDestacada)
  : undefined;

const estatales = comunidades.filter(
  (c) => c.tipo === 'comun-estatal' && c.slug !== comunidadDestacada,
);
const autonomias = comunidades.filter(
  (c) => c.tipo !== 'comun-estatal' && c.slug !== comunidadDestacada,
);

const link = (slug: string) => `${basePath}/${slug}`.replace(/\/{2,}/g, '/');

const BADGES: Record<ComunidadTipo, Record<Lang, string>> = {
  'comun-estatal': { es: 'España', ca: 'Espanya', en: 'Spain' },
  'autonomica': { es: 'CCAA', ca: 'CCAA', en: 'Region' },
  'ciudad-autonoma': { es: 'Ciudad autónoma', ca: 'Ciutat autònoma', en: 'Autonomous city' },
};

const badge = (tipo: ComunidadTipo) => BADGES[tipo][lang] ?? BADGES[tipo].es;
---

{destacada && (
  <section class="cv-section">
    <header class="cv-section-head">
      <h2>{t('grid.headingFeatured', lang)}</h2>
    </header>
    <ul class="cv-grid">
      <li class="cv-card cv-card-destacada">
        <a href={link(destacada.slug)}>
          <span class="cv-badge cv-badge-destacada">{badge(destacada.tipo)}</span>
          <span class="cv-card-title">{destacada.nombre}</span>
          {destacada.vigencia && <span class="cv-card-vigencia">{destacada.vigencia}</span>}
          <span class="cv-card-arrow" aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </section>
)}

{estatales.length > 0 && (
  <section class="cv-section">
    <header class="cv-section-head">
      <h2>{t('grid.headingCommon', lang)}</h2>
      <span class="cv-count">{estatales.length}</span>
    </header>
    <ul class="cv-grid">
      {estatales.map((c) => (
        <li class="cv-card">
          <a href={link(c.slug)}>
            <span class="cv-badge">{badge(c.tipo)}</span>
            <span class="cv-card-title">{c.nombre}</span>
            {c.vigencia && <span class="cv-card-vigencia">{c.vigencia}</span>}
            <span class="cv-card-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

{autonomias.length > 0 && (
  <section class="cv-section">
    <header class="cv-section-head">
      <h2>{t('grid.headingAutonomies', lang)}</h2>
      <span class="cv-count">{autonomias.length}</span>
    </header>
    <ul class="cv-grid">
      {autonomias.map((c) => (
        <li class="cv-card">
          <a href={link(c.slug)}>
            <span class="cv-badge">{badge(c.tipo)}</span>
            <span class="cv-card-title">{c.nombre}</span>
            {c.vigencia && <span class="cv-card-vigencia">{c.vigencia}</span>}
            <span class="cv-card-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
