{
  "name": "larokifarm",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo Larokifarm: landings de farmacias (Astro), widget de chat Cima, calendario de vacunación compartido y Sanity Studio.",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "studio": "pnpm --filter studio dev"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "engines": {
    "pnpm": ">=10",
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.4"
}
