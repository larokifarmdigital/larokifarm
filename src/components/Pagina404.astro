---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import {
  agruparHorarios,
  localizar,
  SLUG_FARMACIA,
  type Farmacia,
  type DiasI18n,
} from '@/lib/sanity';
import { rutaConLocale, t, type Locale } from '@/lib/i18n';
import diasEs from '@/i18n/es.json';
import diasEn from '@/i18n/en.json';
import diasCa from '@/i18n/ca.json';

interface Props {
  farmacia: Farmacia | null;
  lang: Locale;
}

const { farmacia: farmaciaCargada, lang } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const farmacia: Farmacia = farmaciaCargada ?? {
  _id: 'placeholder',
  nombre: 'Farmacia Torrents',
  slug: SLUG_FARMACIA,
};

const DIAS_POR_LANG: Record<Locale, DiasI18n> = {
  es: diasEs.dias as DiasI18n,
  en: diasEn.dias as DiasI18n,
  ca: diasCa.dias as DiasI18n,
};
const CERRADO_LABEL: Record<Locale, string> = {
  es: 'Cerrado', en: 'Closed', ca: 'Tancat',
};
const horariosAgrupados = agruparHorarios(
  farmacia.horarios,
  DIAS_POR_LANG[lang],
  CERRADO_LABEL[lang],
);
const mostrarFaqs = (farmacia.faqs ?? []).some(
  (f) => localizar(f.pregunta, lang) && localizar(f.respuesta, lang),
);

const limpiarTel = (s?: string) => s?.replace(/\s+/g, '');
const telLimpio = limpiarTel(farmacia.contacto?.telefono);
const canonical = `${siteUrl}${rutaConLocale('/404', lang)}`;
const home = rutaConLocale('/', lang);
---

<BaseLayout
  titulo={t('p404.tituloMeta', lang, { nombre: farmacia.nombre })}
  descripcion={t('p404.descMeta', lang)}
  canonical={canonical}
  lang={lang}
  rutaActual='/404'
>
  <script is:inline slot='head'>
    (function () {
      try {
        var m = window.location.pathname.match(/^\/(en|ca)(\/|$)/);
        if (m && window.location.pathname !== '/' + m[1] + '/404') {
          window.location.replace('/' + m[1] + '/404');
        }
      } catch (e) {}
    })();
  </script>

  <Header
    nombre={farmacia.nombre}
    whatsapp={farmacia.contacto?.whatsapp}
    telefono={farmacia.contacto?.telefono}
    logo={farmacia.logo}
    mostrarFaqs={mostrarFaqs}
    lang={lang}
    rutaActual='/404'
    idiomasActivos={farmacia.idiomasActivos}
  />

  <main id='contenido' class='relative flex min-h-[72vh] items-center overflow-hidden py-16 md:py-24'>
    <div class='absolute inset-0' aria-hidden='true'>
      <div class='absolute -top-32 -right-32 h-[24rem] w-[24rem] rounded-full bg-[color-mix(in_oklch,var(--brand-light),transparent_70%)] blur-3xl md:h-[28rem] md:w-[28rem]'></div>
      <div class='absolute -bottom-40 -left-40 h-[28rem] w-[28rem] rounded-full bg-[color-mix(in_oklch,var(--primary),transparent_88%)] blur-3xl md:h-[32rem] md:w-[32rem]'></div>
    </div>

    <div class='container-app relative'>
      <div class='mx-auto max-w-3xl'>
        <div class='text-center'>
          <div class='mb-6 inline-flex items-center gap-2 rounded-full border border-[color-mix(in_oklch,var(--primary),transparent_80%)] bg-[color-mix(in_oklch,var(--primary),transparent_94%)] px-4 py-1.5 text-xs font-bold tracking-[0.12em] text-[var(--primary)] uppercase md:mb-8'>
            <span class='inline-block h-1.5 w-1.5 rounded-full bg-[var(--accent)]'></span>
            <span>{t('p404.chip', lang)}</span>
          </div>

          <h1 class='text-balance text-6xl font-black leading-[1] tracking-tight text-[var(--foreground)] sm:text-7xl md:text-8xl lg:text-9xl'>
            404
          </h1>

          <h2 class='mt-5 text-2xl font-black tracking-tight sm:text-3xl md:mt-6 md:text-4xl'>
            {t('p404.subtitulo1', lang)} <span class='text-[var(--primary)]'>{t('p404.subtitulo2', lang)}</span>
          </h2>

          <p class='mx-auto mt-4 max-w-md text-base leading-relaxed text-[var(--muted-foreground)] md:mt-5 md:text-lg'>
            {t('p404.texto', lang)}
          </p>

          <div class='mt-8 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center md:mt-10'>
            <a href={home} class='btn-primary px-6 py-3.5 text-base sm:px-7 sm:py-4'>
              <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
                <path d='M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2z' />
              </svg>
              {t('p404.btnInicio', lang)}
            </a>
            {
              telLimpio && (
                <a href={`tel:${telLimpio}`} class='btn-secondary px-6 py-3.5 text-base sm:px-7 sm:py-4'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
                    <path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z' />
                  </svg>
                  {t('header.cta.llamanos', lang)}
                </a>
              )
            }
          </div>
        </div>

        <div class='mt-12 md:mt-14'>
          <p class='mb-5 text-center text-xs font-bold tracking-[0.1em] text-[var(--muted-foreground)] uppercase'>
            {t('p404.buscas', lang)}
          </p>
          <div class={`grid gap-2.5 ${mostrarFaqs ? 'sm:grid-cols-2 lg:grid-cols-4' : 'sm:grid-cols-3'}`}>
            <a href={`${home}#servicios`} class='group flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--card)] px-4 py-3 text-sm font-semibold text-[var(--foreground)] transition-colors hover:border-[color-mix(in_oklch,var(--primary),transparent_65%)] hover:text-[var(--primary)]'>
              <svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' class='shrink-0 text-[var(--primary)]'>
                <rect x='3' y='3' width='7' height='7' rx='1' />
                <rect x='14' y='3' width='7' height='7' rx='1' />
                <rect x='3' y='14' width='7' height='7' rx='1' />
                <rect x='14' y='14' width='7' height='7' rx='1' />
              </svg>
              <span>{t('header.nav.servicios', lang)}</span>
            </a>

            <a href={`${home}#sobre`} class='group flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--card)] px-4 py-3 text-sm font-semibold text-[var(--foreground)] transition-colors hover:border-[color-mix(in_oklch,var(--primary),transparent_65%)] hover:text-[var(--primary)]'>
              <svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' class='shrink-0 text-[var(--primary)]'>
                <path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2' />
                <circle cx='9' cy='7' r='4' />
              </svg>
              <span>{t('header.nav.sobreNosotros', lang)}</span>
            </a>

            {
              mostrarFaqs && (
                <a href={`${home}#faqs`} class='group flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--card)] px-4 py-3 text-sm font-semibold text-[var(--foreground)] transition-colors hover:border-[color-mix(in_oklch,var(--primary),transparent_65%)] hover:text-[var(--primary)]'>
                  <svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' class='shrink-0 text-[var(--primary)]'>
                    <circle cx='12' cy='12' r='10' />
                    <path d='M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3' />
                    <line x1='12' y1='17' x2='12.01' y2='17' />
                  </svg>
                  <span>{t('header.nav.faqs', lang)}</span>
                </a>
              )
            }

            <a href={`${home}#contacto`} class='group flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--card)] px-4 py-3 text-sm font-semibold text-[var(--foreground)] transition-colors hover:border-[color-mix(in_oklch,var(--primary),transparent_65%)] hover:text-[var(--primary)]'>
              <svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' class='shrink-0 text-[var(--primary)]'>
                <path d='M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z' />
                <circle cx='12' cy='10' r='3' />
              </svg>
              <span>{t('header.nav.contacto', lang)}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer
    nombre={farmacia.nombre}
    titular={farmacia.titular}
    numeroColegiado={farmacia.numeroColegiado}
    logo={farmacia.logo}
    contacto={farmacia.contacto}
    redes={farmacia.redesSociales}
    direccion={farmacia.direccion}
    horarios={farmacia.horarios}
    horariosAgrupados={horariosAgrupados}
    servicios={farmacia.servicios}
    descripcionCorta={farmacia.descripcionCorta}
    mostrarFaqs={mostrarFaqs}
    lang={lang}
    rutaActual='/404'
  />
</BaseLayout>
