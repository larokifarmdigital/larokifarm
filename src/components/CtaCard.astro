---
import type { Direccion, GrupoHorario } from '@/lib/sanity';
import MarcaAgua from '@/components/MarcaAgua.astro';
import { t, type Locale } from '@/lib/i18n';

export interface Props {
  nombre?: string;
  telefono?: string;
  whatsapp?: string;
  direccion?: Direccion;
  mapaUrl?: string;
  horarios?: GrupoHorario[];
  logo?: string;
  lang: Locale;
}

const {
  nombre = '',
  telefono,
  whatsapp,
  direccion,
  mapaUrl,
  horarios = [],
  logo,
  lang
} = Astro.props;

const direccionCorta = direccion
  ? [direccion.calle, direccion.ciudad].filter(Boolean).join(', ')
  : null;

const direccionLarga = direccion
  ? [direccion.calle, direccion.codigoPostal, direccion.ciudad].filter(Boolean).join(', ')
  : null;

function extraerCoordenadas(url: string): { lat: number; lng: number } | null {
  const match = url.match(/@(-?\d+\.\d+),(-?\d+\.\d+)/);
  if (!match) return null;
  const lat = parseFloat(match[1]);
  const lng = parseFloat(match[2]);
  if (Number.isNaN(lat) || Number.isNaN(lng)) return null;
  return { lat, lng };
}

function aplicarIdiomaMaps(url: string, hl: string): string {
  let modificada = url.replace(
    /(!\dm2!1s)[a-z]{2}(!2s)[a-z]{2}/g,
    (_m, p1: string, p2: string) => `${p1}${hl}${p2}${hl}`,
  );
  if (/[?&]hl=[^&]*/.test(modificada)) {
    modificada = modificada.replace(/([?&])hl=[^&]*/, `$1hl=${hl}`);
  } else {
    modificada += (modificada.includes('?') ? '&' : '?') + `hl=${hl}`;
  }
  return modificada;
}

function construirEmbed(): string | null {
  if (mapaUrl) {
    if (mapaUrl.includes('/maps/embed')) {
      return aplicarIdiomaMaps(mapaUrl, lang);
    }
    const coords = extraerCoordenadas(mapaUrl);
    if (coords) {
      return `https://maps.google.com/maps?q=${coords.lat},${coords.lng}&z=16&hl=${lang}&output=embed`;
    }
  }
  if (direccionLarga) {
    return `https://maps.google.com/maps?q=${encodeURIComponent(direccionLarga)}&z=16&hl=${lang}&output=embed`;
  }
  return null;
}

const embedUrl = construirEmbed();

const limpiarTel = (s?: string) => s?.replace(/\s+/g, '');
const waUrl = whatsapp ? `https://wa.me/${limpiarTel(whatsapp)?.replace(/^\+/, '')}` : null;

const ciudad = direccion?.ciudad;
const tituloCiudad = ciudad ? t('cta.tituloConCiudad', lang, { ciudad }) : '';
const tituloSinCiudadParts = t('cta.tituloSinCiudad', lang);
// Para resaltar la última palabra
function partirParaResaltar(texto: string): { inicio: string; fin: string } {
  const palabras = texto.split(' ');
  if (palabras.length < 2) return { inicio: '', fin: texto };
  return {
    inicio: palabras.slice(0, palabras.length - 1).join(' '),
    fin: palabras[palabras.length - 1]
  };
}
const titulo = ciudad ? partirParaResaltar(tituloCiudad) : partirParaResaltar(tituloSinCiudadParts);
---

<section id='contacto' class='relative overflow-hidden pb-24 pt-24'>
  <MarcaAgua
    logo={logo}
    class='top-8 right-6 md:right-16'
    tamano={64}
    opacidad={0.05}
    rotacion={8}
  />
  <MarcaAgua
    logo={logo}
    class='bottom-10 left-6 md:left-16'
    tamano={56}
    opacidad={0.05}
    rotacion={-10}
  />
  <MarcaAgua
    logo={logo}
    class='top-1/2 left-1/3 -translate-y-1/2'
    tamano={80}
    opacidad={0.04}
    rotacion={14}
  />

  <div class='container-app relative'>
    <div
      class='relative overflow-hidden rounded-4xl border bg-card shadow-2xl'
      style='box-shadow: 0 25px 50px -12px color-mix(in oklch, var(--primary), transparent 85%);'
    >
      <div
        class='absolute top-0 right-0 h-96 w-96 rounded-full bg-[color-mix(in_oklch,var(--primary),transparent_90%)] blur-3xl'
        aria-hidden='true'
      >
      </div>
      <div
        class='absolute bottom-0 left-0 h-80 w-80 rounded-full bg-[color-mix(in_oklch,var(--accent),transparent_90%)] blur-3xl'
        aria-hidden='true'
      >
      </div>
      <div class='dot-pattern absolute inset-0 opacity-50' aria-hidden='true'></div>

      <div class='relative grid lg:grid-cols-[1.1fr_1fr]'>
        {
          embedUrl && (
            <div class='order-2 aspect-4/3 w-full overflow-hidden border-t border-border lg:order-1 lg:aspect-auto lg:border-t-0 lg:border-r'>
              <iframe
                src={embedUrl}
                title={t('cta.ariaMapa', lang, { nombre })}
                loading='lazy'
                referrerpolicy='no-referrer-when-downgrade'
                class='block h-full min-h-80 w-full border-0'
              />
            </div>
          )
        }

        <div
          class={`order-1 min-w-0 px-5 py-12 sm:px-8 md:px-12 md:py-16 lg:order-2 lg:py-20 ${embedUrl ? '' : 'lg:col-span-2'}`}
        >
          <div class='max-w-md space-y-6 text-start md:mx-auto md:text-center'>
            <div class='chip inline-flex max-w-full'>
              <svg
                width='14'
                height='14'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2.2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
              >
                <path
                  d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z'
                >
                </path>
              </svg>
              <span>{t('cta.chip', lang)}</span>
            </div>

            <h2
              class='text-2xl font-extrabold tracking-tight wrap-break-word sm:text-3xl md:text-4xl lg:text-[2.2rem]'
            >
              {titulo.inicio}{titulo.inicio && ' '}<span class='text-primary'>{titulo.fin}</span>
            </h2>

            <p class='text-base text-muted-foreground md:text-lg'>
              {t('cta.subtitulo', lang, { nombre })}
            </p>

            <div class='space-y-1 text-left'>
              {
                telefono && (
                  <div class='flex items-center gap-4 rounded-2xl border border-transparent px-4 py-3.5'>
                    <span class='flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[color-mix(in_oklch,var(--primary),transparent_88%)] text-primary'>
                      <svg
                        width='20'
                        height='20'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2.2'
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        aria-hidden='true'
                      >
                        <path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z' />
                      </svg>
                    </span>
                    <span class='min-w-0 flex-1 text-left'>
                      <span class='block text-xs font-bold tracking-wider text-muted-foreground uppercase'>
                        {t('cta.labelTelefono', lang)}
                      </span>
                      <span class='block truncate font-extrabold text-foreground'>{telefono}</span>
                    </span>
                  </div>
                )
              }
              {
                direccionCorta && (
                  <div class='flex items-center gap-4 rounded-2xl border border-transparent px-4 py-3.5'>
                    <span class='flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[color-mix(in_oklch,var(--accent),transparent_88%)] text-accent'>
                      <svg
                        width='20'
                        height='20'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2.2'
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        aria-hidden='true'
                      >
                        <path d='M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z' />
                        <circle cx='12' cy='10' r='3' />
                      </svg>
                    </span>
                    <span class='min-w-0 flex-1 text-left'>
                      <span class='block text-xs font-bold tracking-wider text-muted-foreground uppercase'>
                        {t('cta.labelDireccion', lang)}
                      </span>
                      <span class='block truncate font-extrabold text-foreground'>
                        {direccionCorta}
                      </span>
                    </span>
                  </div>
                )
              }
              {
                horarios.length > 0 && (
                  <div class='flex items-start gap-4 rounded-2xl border border-transparent px-4 py-3.5'>
                    <span
                      class='mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-xl'
                      style='background: color-mix(in oklch, var(--kids-green), transparent 88%); color: var(--kids-green);'
                    >
                      <svg
                        width='20'
                        height='20'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2.2'
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        aria-hidden='true'
                      >
                        <circle cx='12' cy='12' r='10' />
                        <path d='M12 6v6l4 2' />
                      </svg>
                    </span>
                    <span class='min-w-0 flex-1'>
                      <span class='block text-xs font-bold tracking-wider text-muted-foreground uppercase'>
                        {t('cta.labelHorario', lang)}
                      </span>
                      <ul class='mt-1 space-y-1 text-sm md:text-base'>
                        {horarios.map(h => (
                          <li class='flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5'>
                            <span class='font-extrabold text-foreground'>{h.etiqueta}</span>
                            <span class='text-muted-foreground'>{h.horario}</span>
                          </li>
                        ))}
                      </ul>
                    </span>
                  </div>
                )
              }
            </div>

            <div class='flex flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap sm:justify-center'>
              {
                waUrl && (
                  <a
                    href={waUrl}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='btn-wa w-full sm:w-auto'
                  >
                    <svg
                      width='18'
                      height='18'
                      viewBox='0 0 24 24'
                      fill='currentColor'
                      aria-hidden='true'
                    >
                      <path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488' />
                    </svg>
                    {t('cta.btnEscribenos', lang)}
                  </a>
                )
              }
              {
                telefono && (
                  <a href={`tel:${limpiarTel(telefono)}`} class='btn-primary w-full sm:w-auto'>
                    {t('cta.btnLlamar', lang)}
                  </a>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
