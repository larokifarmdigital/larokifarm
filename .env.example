# Todas las variables son REQUERIDAS. Si falta alguna, el build falla.
# Copia este archivo como .env para desarrollo local y rellena los valores.
# En producción, defínelas en las Environment variables de Cloudflare Pages.

# Slug del documento Farmacia en Sanity que carga esta build.
# Cambia este valor en cada deploy para servir una farmacia distinta.
PUBLIC_FARMACIA_SLUG=torrents

# URL pública del sitio (sin barra al final).
# Se usa para canonical, sitemap, Open Graph y JSON-LD.
SITE_URL=https://farmaciatorrents.example

# Project ID y dataset de Sanity. No son secretos (viajan en cada request).
PUBLIC_SANITY_PROJECT_ID=yovi040n
PUBLIC_SANITY_DATASET=calendario
