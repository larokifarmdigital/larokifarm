---
import {
  localizar,
  type ResumenResenas,
  type TextosCabecera,
} from '@/lib/sanity';
import { rutaConLocale, t, type Locale } from '@/lib/i18n';

interface Props {
  resumen: ResumenResenas;
  urlGoogleMaps?: string;
  textos?: TextosCabecera;
  lang: Locale;
}

const { resumen, urlGoogleMaps, textos, lang } = Astro.props;

const chip = localizar(textos?.chip, lang) || t('resenas.chip', lang);
const titulo = localizar(textos?.titulo, lang) || t('resenas.titulo', lang);
const media = resumen.media > 0 ? resumen.media.toFixed(1) : '—';
const subtitulo =
  localizar(textos?.subtitulo, lang) ||
  (resumen.total > 0
    ? t('resenas.subtitulo', lang, { total: resumen.total, media })
    : t('resenas.subtituloSinNumero', lang));

const items = [...(resumen.destacadas ?? []), ...(resumen.recientes ?? [])]
  .filter((r) => r?.comentario)
  .slice(0, 6);

function relativo(fechaIso: string): string {
  const ahora = Date.now();
  const fecha = new Date(fechaIso).getTime();
  const diff = Math.max(0, ahora - fecha);
  const dia = 1000 * 60 * 60 * 24;
  const dias = Math.round(diff / dia);
  if (dias < 1) return t('resenas.hace.ahora', lang);
  if (dias < 14) return t(dias === 1 ? 'resenas.hace.diasUno' : 'resenas.hace.diasN', lang, { n: dias });
  const semanas = Math.round(dias / 7);
  if (dias < 60) return t(semanas === 1 ? 'resenas.hace.semanasUno' : 'resenas.hace.semanasN', lang, { n: semanas });
  const meses = Math.round(dias / 30);
  if (dias < 365) return t(meses === 1 ? 'resenas.hace.mesesUno' : 'resenas.hace.mesesN', lang, { n: meses });
  const anyos = Math.round(dias / 365);
  return t(anyos === 1 ? 'resenas.hace.anyosUno' : 'resenas.hace.anyosN', lang, { n: anyos });
}

function inicial(nombre?: string): string {
  return nombre?.trim()[0]?.toUpperCase() ?? '?';
}

if (items.length === 0) return null;
---

<section id='resenas' class='py-[clamp(4rem,7vw,6rem)]'>
  <div class='container-app'>
    <header class='max-w-[60ch] mx-auto mb-[clamp(2rem,3vw,3rem)] text-center flex flex-col gap-3 items-center'>
      <span class='section-eyebrow'>{chip}</span>
      <h2 class='h-section mt-1'>{titulo}</h2>
      <p class='m-0 text-[color:var(--muted-foreground)]'>{subtitulo}</p>
    </header>

    {resumen.total > 0 && (
      <div class='card grid grid-cols-1 sm:grid-cols-[auto_1fr_auto] gap-4 items-center max-w-[700px] mx-auto mb-[clamp(2rem,3vw,3rem)] text-center sm:text-left bg-[color:var(--surface)]'>
        <div class='inline-flex items-baseline gap-1 justify-center'>
          <span class='text-[2.75rem] font-bold -tracking-[0.03em] text-[color:var(--foreground)] leading-none'>{media}</span>
          <span class='text-[color:var(--muted)] text-base font-medium'>/ 5,0</span>
        </div>
        <div class='flex flex-col gap-1 items-center sm:items-start'>
          <div
            class='text-[color:var(--warning)] inline-flex gap-[2px]'
            aria-label={t('resenas.ariaEstrellas', lang, { rating: media })}
          >
            {Array.from({ length: 5 }).map((_, i) => (
              <svg width='18' height='18' viewBox='0 0 24 24' fill={i < Math.round(resumen.media) ? 'currentColor' : 'none'} stroke='currentColor' stroke-width='1.5' stroke-linejoin='round' aria-hidden='true'>
                <path d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' />
              </svg>
            ))}
          </div>
          <p class='resenas-total m-0 text-[color:var(--muted-foreground)] text-[0.85rem]'>
            Basado en <strong>{resumen.total}</strong> reseñas de Google
          </p>
        </div>
        {urlGoogleMaps && (
          <a href={urlGoogleMaps} target='_blank' rel='noopener noreferrer' class='btn btn-secondary'>
            Ver en Google
            <svg width='12' height='12' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
              <path d='M7 17L17 7M9 7h8v8' />
            </svg>
          </a>
        )}
      </div>
    )}

    <ul class='list-none p-0 m-0 grid grid-cols-1 sm:grid-cols-2 min-[960px]:grid-cols-3 gap-4'>
      {items.map((r) => (
        <li class='card flex flex-col gap-[0.85rem]'>
          <header class='grid grid-cols-[40px_1fr_auto] gap-[0.65rem] items-center'>
            {r.autorFotoUrl ? (
              <img
                src={r.autorFotoUrl}
                alt=''
                loading='lazy'
                referrerpolicy='no-referrer'
                class='w-10 h-10 rounded-full object-cover bg-[color:var(--primary-soft)]'
              />
            ) : (
              <span
                class='w-10 h-10 rounded-full object-cover inline-flex items-center justify-center bg-[color:var(--accent)] text-white font-semibold text-base'
                aria-hidden='true'
              >
                {inicial(r.autorNombre)}
              </span>
            )}
            <div class='min-w-0 flex flex-col gap-[0.1rem]'>
              <p class='m-0 text-[0.9rem] font-semibold text-[color:var(--foreground)] overflow-hidden text-ellipsis whitespace-nowrap'>
                {r.autorNombre ?? t('resenas.anonimo', lang)}
              </p>
              <time datetime={r.fechaPublicacion} class='text-[0.75rem] text-[color:var(--muted)]'>{relativo(r.fechaPublicacion)}</time>
            </div>
            <div
              class='text-[color:var(--warning)] inline-flex gap-[1px]'
              aria-label={t('resenas.ariaEstrellas', lang, { rating: r.rating })}
            >
              {Array.from({ length: 5 }).map((_, j) => (
                <svg width='12' height='12' viewBox='0 0 24 24' fill={j < r.rating ? 'currentColor' : 'none'} stroke='currentColor' stroke-width='1.5' stroke-linejoin='round' aria-hidden='true'>
                  <path d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' />
                </svg>
              ))}
            </div>
          </header>
          <p class='m-0 text-[color:var(--muted-foreground)] text-[0.9rem] leading-[1.55]'>{r.comentario}</p>
        </li>
      ))}
    </ul>

    <div class='mt-[clamp(2rem,3vw,3rem)] flex justify-center'>
      <a href={rutaConLocale('/resenas', lang)} class='btn btn-secondary'>
        {t('resenas.verTodas', lang)}
        <svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
          <path d='M5 12h14M13 6l6 6-6 6' />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* <strong> descendiente dentro del texto total de reseñas — el color destino
     depende del texto que rodea al elemento y no se puede tocar con clases inline. */
  .resenas-total strong { color: var(--foreground); font-weight: 600; }
</style>
