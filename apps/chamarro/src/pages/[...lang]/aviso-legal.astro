---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import {
  obtenerFarmaciaPorSlug,
  localizar,
  portableTextAHtml,
  SLUG_FARMACIA,
  type Farmacia,
} from '@/lib/sanity';
import {
  esLocaleValido,
  rutaConLocale,
  t,
  type Locale,
} from '@/lib/i18n';
import { LEGAL } from '@/lib/legal';
import { MOSTRAR_RESENAS } from '@/lib/feature-flags';

export async function getStaticPaths() {
  const farmacia = await obtenerFarmaciaPorSlug(SLUG_FARMACIA);
  const codigos = (farmacia?.idiomasActivos ?? [{ codigo: 'es', nombre: 'Español' }])
    .map((i) => i.codigo)
    .filter(esLocaleValido);
  const lista = codigos.length > 0 ? codigos : (['es'] as Locale[]);
  return lista.map((c) => ({
    params: { lang: c === 'es' ? undefined : c },
    props: { farmacia, lang: c },
  }));
}

interface Props { farmacia: Farmacia | null; lang: Locale; }
const { farmacia: farmaciaCargada, lang } = Astro.props as Props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const farmacia: Farmacia = farmaciaCargada ?? {
  _id: 'placeholder',
  nombre: 'Farmacia Chamarro',
  slug: SLUG_FARMACIA,
};

const mostrarFaqs = (farmacia.faqs ?? []).some(
  (f) => localizar(f.pregunta, lang) && localizar(f.respuesta, lang),
);

const canonical = `${siteUrl}${rutaConLocale('/aviso-legal', lang)}`;
const home = rutaConLocale('/', lang);

const avisoHtml =
  portableTextAHtml(localizar(farmacia.avisoLegal, lang)) || LEGAL[lang].avisoLegal;
---

<BaseLayout
  titulo={`${t('legal.avisoTitulo', lang)} · ${farmacia.nombre}`}
  descripcion={t('legal.avisoMeta', lang, { nombre: farmacia.nombre })}
  canonical={canonical}
  lang={lang}
  rutaActual='/aviso-legal'
>
  <Header
    nombre={farmacia.nombre}
    telefono={farmacia.contacto?.telefono}
    logo={farmacia.logo}
    mostrarFaqs={mostrarFaqs}
    mostrarResenas={MOSTRAR_RESENAS}
    lang={lang}
    rutaActual='/aviso-legal'
    idiomasActivos={farmacia.idiomasActivos}
  />

  <main id='contenido' class='container-app legal-page'>
    <a href={home} class='legal-page__volver'>
      <svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
        <path d='m15 18-6-6 6-6' />
      </svg>
      {t('legal.volver', lang)}
    </a>

    <article class='legal-page__cms' set:html={avisoHtml} />
  </main>

  <Footer
    nombre={farmacia.nombre}
    titular={farmacia.titular}
    numeroColegiado={farmacia.numeroColegiado}
    logo={farmacia.logo}
    contacto={farmacia.contacto}
    redes={farmacia.redesSociales}
    direccion={farmacia.direccion}
    mostrarFaqs={mostrarFaqs}
    lang={lang}
    rutaActual='/aviso-legal'
  />
</BaseLayout>

<style>
  .legal-page {
    padding-block: clamp(3rem, 6vw, 6rem);
    max-width: 720px;
  }
  .legal-page__volver {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 2rem;
  }
  .legal-page__volver:hover { color: var(--foreground); }

  .legal-page__cms :global(h1) {
    font-size: clamp(2rem, 3vw + 0.5rem, 2.75rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
    font-weight: 700;
    color: var(--foreground);
    margin: 0 0 2rem;
  }
  .legal-page__cms :global(h2) {
    font-size: 1.35rem;
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.015em;
    font-weight: 700;
    color: var(--foreground);
  }
  .legal-page__cms :global(h3) {
    font-size: 1rem;
    margin: 1.75rem 0 0.5rem;
    font-weight: 600;
    color: var(--foreground);
  }
  .legal-page__cms :global(p),
  .legal-page__cms :global(li) {
    line-height: 1.7;
    color: var(--muted-foreground);
    font-size: 0.95rem;
  }
  .legal-page__cms :global(p) { margin: 0 0 1rem; }
  .legal-page__cms :global(ul),
  .legal-page__cms :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .legal-page__cms :global(ul) { list-style: disc; }
  .legal-page__cms :global(ol) { list-style: decimal; }
  .legal-page__cms :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    word-break: break-word;
  }
  .legal-page__cms :global(a:hover) { color: var(--accent-hover); }
  .legal-page__cms :global(strong) { color: var(--foreground); font-weight: 600; }
</style>
