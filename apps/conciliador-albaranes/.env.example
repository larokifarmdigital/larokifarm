# ──────────────────────────────────────────────────────────────
# Conciliador de Albaranes — variables de entorno
# Copia este archivo a `.env.local` para desarrollo (no commiteado).
# Para producción ver docs/multi-tenant.md §5.
# ──────────────────────────────────────────────────────────────

# Auth.js (Fase 1)
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-en-produccion-openssl-rand-base64-32"

# Postgres local (Fase 1) — docker-compose.dev.yml
# En producción se sustituye por las URLs del Managed Postgres de DigitalOcean
# (ver docs/multi-tenant.md §5 para el formato con pooler + directo).
DATABASE_URL="postgresql://conciliador:conciliador@localhost:5432/conciliador_dev"
DIRECT_DATABASE_URL="postgresql://conciliador:conciliador@localhost:5432/conciliador_dev"

# Gemini (key global por defecto)
GEMINI_API_KEY=""

# Seed inicial (Fase 1) — script scripts/seed.ts
SEED_SUPER_ADMIN_EMAIL="erick@laroki.com"
SEED_SUPER_ADMIN_PASSWORD="changeme123"
SEED_SUPER_ADMIN_NAME="Erick"

# Cifrado BYOK (Fase 2) — 32 bytes base64
# Generar con: openssl rand -base64 32
ENCRYPTION_KEY="cambiar-en-produccion-openssl-rand-base64-32"

# Storage (Fase 2): "local" (dev) o "spaces" (prod)
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"

# DO Spaces (solo cuando STORAGE_DRIVER=spaces)
# SPACES_ENDPOINT="https://fra1.digitaloceanspaces.com"
# SPACES_KEY=""
# SPACES_SECRET=""
# SPACES_BUCKET="conciliador"
