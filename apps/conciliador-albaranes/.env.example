# ──────────────────────────────────────────────────────────────
# Conciliador de Albaranes — variables de entorno
# Copia este archivo a `.env.local` para desarrollo (no commiteado).
# Para producción ver docs/multi-tenant.md §5.
# ──────────────────────────────────────────────────────────────

# Auth.js (Fase 1)
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-en-produccion-openssl-rand-base64-32"

# Postgres (Neon en producción / dev compartido).
# Pooled (pgbouncer) para la app, direct para `prisma migrate`.
DATABASE_URL="postgresql://USER:PASS@ep-XXXX-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://USER:PASS@ep-XXXX.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Gemini (key global por defecto)
GEMINI_API_KEY=""

# Seed inicial (Fase 1) — script scripts/seed.ts
SEED_SUPER_ADMIN_EMAIL="erick@laroki.com"
SEED_SUPER_ADMIN_PASSWORD="changeme123"
SEED_SUPER_ADMIN_NAME="Erick"

# Cifrado BYOK (Fase 2) — 32 bytes base64
# Generar con: openssl rand -base64 32
ENCRYPTION_KEY="cambiar-en-produccion-openssl-rand-base64-32"

# Storage: "local" (dev) o "r2" (prod, Cloudflare R2 — S3-compatible)
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"

# Cloudflare R2 (solo cuando STORAGE_DRIVER=r2)
# Endpoint con jurisdicción EU.
# R2_ENDPOINT="https://<accountid>.eu.r2.cloudflarestorage.com"
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="conciliador-albaranes"
