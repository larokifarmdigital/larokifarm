---
import { imagenSanity } from '@/lib/sanity';
import type { IdiomaActivo } from '@/lib/sanity';
import { t, rutaConLocale, LOCALES_DISPONIBLES, esLocaleValido, type Locale } from '@/lib/i18n';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  nombre: string;
  whatsapp?: string;
  telefono?: string;
  logo?: string;
  mostrarFaqs?: boolean;
  /** Si false, omite el enlace de Reseñas del nav y de la hamburguesa. */
  mostrarResenas?: boolean;
  lang: Locale;
  /** Ruta lógica (sin prefijo de idioma) usada para construir enlaces de cambio de idioma. */
  rutaActual?: string;
  /** Idiomas activos de ESTA farmacia (subset del global). Si no se pasa, usa todos los locales globales. */
  idiomasActivos?: IdiomaActivo[];
  /** Versión compacta sin nav de secciones (para páginas internas). */
  compacto?: boolean;
  /** Migas de pan opcionales; si está presente, se renderiza una barra debajo del header. */
  breadcrumb?: BreadcrumbItem[];
}

const {
  nombre,
  whatsapp,
  telefono,
  logo,
  mostrarFaqs = false,
  mostrarResenas = true,
  lang,
  rutaActual = '/',
  idiomasActivos,
  compacto = false,
  breadcrumb
} = Astro.props;

const idiomasSelector: Locale[] =
  idiomasActivos && idiomasActivos.length > 0
    ? idiomasActivos.map(i => i.codigo).filter(esLocaleValido)
    : [...LOCALES_DISPONIBLES];

const logoOpt = imagenSanity(logo, { w: 96, h: 96, fit: 'crop' });
const limpiarTel = (t?: string) => t?.replace(/\s+/g, '');
const telLimpio = limpiarTel(telefono);
const waUrl = whatsapp ? `https://wa.me/${limpiarTel(whatsapp)?.replace(/^\+/, '')}` : null;

const inicioUrl = rutaConLocale('/', lang);

const enlaces = compacto
  ? []
  : [
      { href: `${inicioUrl}#inicio`, label: t('header.nav.inicio', lang) },
      { href: `${inicioUrl}#servicios`, label: t('header.nav.servicios', lang) },
      { href: `${inicioUrl}#sobre`, label: t('header.nav.sobreNosotros', lang) },
      ...(mostrarResenas
        ? [{ href: `${inicioUrl}#resenas`, label: t('header.nav.resenas', lang) }]
        : []),
      ...(mostrarFaqs ? [{ href: `${inicioUrl}#faqs`, label: t('header.nav.faqs', lang) }] : []),
      { href: `${inicioUrl}#contacto`, label: t('header.nav.contacto', lang) }
    ];

const tieneBreadcrumb = !!(breadcrumb && breadcrumb.length > 0);

const llamarLabel = telefono ? t('header.cta.llamarA', lang, { telefono }) : '';
---

<header
  class='fixed top-0 right-0 left-0 z-50 border-b border-[var(--border)] bg-[color-mix(in_oklch,var(--card),transparent_5%)] shadow-sm backdrop-blur-xl'
>
  <div class='container-app flex h-16 items-center justify-between'>
    <a href={inicioUrl} class='flex items-center gap-2.5'>
      {
        logoOpt ? (
          <img src={logoOpt} alt='' width='40' height='40' class='h-10 w-10 object-contain' />
        ) : null
      }
      <span class='text-xl font-extrabold tracking-tight text-[var(--primary)]'>{nombre}</span>
    </a>

    {
      enlaces.length > 0 && (
        <nav class='hidden items-center gap-8 lg:flex' aria-label={t('header.nav.aria', lang)}>
          {enlaces.map(l => (
            <a
              href={l.href}
              class='nav-link text-[color-mix(in_oklch,var(--foreground),transparent_30%)] font-bold transition-colors hover:text-[var(--primary)]'
            >
              {l.label}
            </a>
          ))}
        </nav>
      )
    }

    <div class='flex items-center gap-2'>
      <div class='relative hidden lg:block'>
        <button
          type='button'
          class='flex items-center gap-1.5 rounded-xl border border-border bg-card px-3 py-2 text-sm font-bold uppercase tracking-wider text-foreground transition-colors hover:border-primary hover:text-primary'
          aria-label={t('header.idioma.aria', lang)}
          aria-haspopup='true'
          aria-expanded='false'
          data-lang-toggle
        >
          <svg
            width='16'
            height='16'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2.2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
          >
            <circle cx='12' cy='12' r='10'></circle>
            <line x1='2' y1='12' x2='22' y2='12'></line>
            <path
              d='M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z'
            >
            </path>
          </svg>
          <span class='tabular-nums'>{lang}</span>
        </button>
        <ul
          class='absolute right-0 z-50 mt-2 hidden min-w-32 overflow-hidden rounded-xl border border-border bg-card shadow-lg'
          data-lang-menu
        >
          {
            idiomasSelector.map(codigo => (
              <li>
                <a
                  href={rutaConLocale(rutaActual, codigo)}
                  data-lang-link
                  class:list={[
                    'block px-4 py-2 text-sm font-semibold transition-colors hover:bg-secondary',
                    codigo === lang ? 'text-primary' : 'text-foreground'
                  ]}
                >
                  {codigo.toUpperCase()}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {
        telefono && telLimpio && (
          <>
            <a
              href={`tel:${telLimpio}`}
              aria-label={llamarLabel}
              class='btn-primary !px-4 !py-2.5 !text-sm hidden md:inline-flex'
            >
              <svg
                width='16'
                height='16'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2.4'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
              >
                <path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z' />
              </svg>
              <span class='font-extrabold'>{t('header.cta.llamanos', lang)}</span>
              <span class='hidden tabular-nums md:inline lg:hidden xl:inline'>{telefono}</span>
            </a>
            <a
              href={`tel:${telLimpio}`}
              aria-label={llamarLabel}
              class='flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--primary)] text-white md:hidden'
            >
              <svg
                width='18'
                height='18'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2.4'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
              >
                <path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z' />
              </svg>
            </a>
          </>
        )
      }
      <button
        type='button'
        class='inline-flex h-10 w-10 items-center justify-center rounded-xl bg-transparent text-[var(--foreground)] lg:hidden'
        aria-label={t('header.menu.abrir', lang)}
        aria-expanded='false'
        data-menu-toggle
      >
        <svg
          width='22'
          height='22'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2.2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
          data-menu-icon-open
        >
          <line x1='3' y1='6' x2='21' y2='6'></line>
          <line x1='3' y1='12' x2='21' y2='12'></line>
          <line x1='3' y1='18' x2='21' y2='18'></line>
        </svg>
        <svg
          width='22'
          height='22'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2.2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
          class='hidden'
          data-menu-icon-close
        >
          <line x1='18' y1='6' x2='6' y2='18'></line>
          <line x1='6' y1='6' x2='18' y2='18'></line>
        </svg>
      </button>
    </div>
  </div>

  <div class='hidden border-t border-[var(--border)] bg-[var(--card)] lg:hidden' data-mobile-menu>
    <div class='container-app space-y-1 py-4'>
      {
        enlaces.map(l => (
          <a
            href={l.href}
            class='block rounded-xl px-3 py-3 text-[var(--foreground)] transition-colors hover:bg-[var(--secondary)]'
            data-menu-link
          >
            {l.label}
          </a>
        ))
      }
      <div class='flex gap-1.5 px-3 pt-2'>
        {
          idiomasSelector.map(codigo => (
            <a
              href={rutaConLocale(rutaActual, codigo)}
              data-lang-link
              class:list={[
                'rounded-lg border border-border px-3 py-1.5 text-xs font-bold uppercase tracking-wider transition-colors',
                codigo === lang
                  ? 'bg-primary text-white border-primary'
                  : 'text-foreground hover:bg-secondary'
              ]}
            >
              {codigo}
            </a>
          ))
        }
      </div>
      {
        telefono && telLimpio && (
          <a
            href={`tel:${telLimpio}`}
            class='btn-primary mt-2 w-full !justify-center'
            data-menu-link
          >
            <svg
              width='16'
              height='16'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.4'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
            >
              <path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z' />
            </svg>
            {llamarLabel}
          </a>
        )
      }
      {
        waUrl && (
          <a
            href={waUrl}
            target='_blank'
            rel='noopener noreferrer'
            class='btn-wa mt-2 w-full !justify-center'
            data-menu-link
          >
            <svg width='18' height='18' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
              <path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488' />
            </svg>
            WhatsApp
          </a>
        )
      }
    </div>
  </div>
</header>

<div class='h-16' aria-hidden='true'></div>

{
  tieneBreadcrumb && (
    <nav
      class='border-b border-[var(--border)] bg-[color-mix(in_oklch,var(--card),transparent_15%)] backdrop-blur'
      aria-label={t('header.breadcrumb.aria', lang)}
    >
      <div class='container-app'>
        <ol class='flex flex-wrap items-center gap-x-2 gap-y-1 py-2.5 text-sm text-[var(--muted-foreground)]'>
          {breadcrumb!.map((item, i) => (
            <li class='flex items-center gap-2'>
              {i > 0 && (
                <span class='select-none text-[var(--border)]' aria-hidden='true'>
                  /
                </span>
              )}
              {i === breadcrumb!.length - 1 || !item.href ? (
                <span class='font-semibold text-[var(--foreground)]' aria-current='page'>
                  {item.label}
                </span>
              ) : (
                <a
                  href={item.href}
                  class='transition-colors hover:text-[var(--primary)] hover:underline underline-offset-4'
                >
                  {item.label}
                </a>
              )}
            </li>
          ))}
        </ol>
      </div>
    </nav>
  )
}

<style>
  .menu-mobile {
    overflow: hidden;
    height: 0;
    opacity: 0;
    transition:
      height 320ms cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 220ms ease-out;
  }
  .menu-mobile[data-abierto='true'] {
    opacity: 1;
  }
  .menu-mobile[data-cerrando='true'] {
    opacity: 0;
  }
  [data-lang-menu]:not(.hidden) {
    display: block;
  }
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.375rem;
    height: 2px;
    background: var(--primary);
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 220ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .menu-mobile,
    .nav-link::after {
      transition: none;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const iconOpen = document.querySelector<HTMLElement>('[data-menu-icon-open]');
  const iconClose = document.querySelector<HTMLElement>('[data-menu-icon-close]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-menu-link]');

  const langBtn = document.querySelector<HTMLButtonElement>('[data-lang-toggle]');
  const langMenu = document.querySelector<HTMLElement>('[data-lang-menu]');

  let animando = false;

  function alturaContenido(el: HTMLElement): number {
    return el.scrollHeight;
  }

  function alFinHeight(el: HTMLElement, callback: () => void) {
    function handler(evento: TransitionEvent) {
      if (evento.propertyName !== 'height') return;
      el.removeEventListener('transitionend', handler as EventListener);
      callback();
    }
    el.addEventListener('transitionend', handler as EventListener);
  }

  function abrir() {
    if (!menu || !btn || !iconOpen || !iconClose || animando) return;
    animando = true;

    menu.dataset.abierto = 'true';
    menu.style.height = '0px';
    requestAnimationFrame(() => {
      menu.style.height = alturaContenido(menu) + 'px';
    });
    alFinHeight(menu, () => {
      menu.style.height = 'auto';
      animando = false;
    });

    btn.setAttribute('aria-expanded', 'true');
    const labelCerrar = btn.dataset.labelCerrar ?? 'Close menu';
    btn.setAttribute('aria-label', labelCerrar);
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
  }

  function cerrar() {
    if (!menu || !btn || !iconOpen || !iconClose) return;
    menu.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
    const labelAbrir = btn.dataset.labelAbrir ?? 'Open menu';
    btn.setAttribute('aria-label', labelAbrir);
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  function alternar() {
    if (!menu || !btn || !iconOpen || !iconClose) return;
    const abierto = !menu.classList.contains('hidden');
    if (abierto) {
      cerrar();
    } else {
      menu.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Cerrar menú');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
    }
  }

  btn?.addEventListener('click', alternar);
  links.forEach(l => l.addEventListener('click', cerrar));

  if (langBtn && langMenu) {
    langBtn.addEventListener('click', e => {
      e.stopPropagation();
      const abierto = !langMenu.classList.contains('hidden');
      if (abierto) {
        langMenu.classList.add('hidden');
        langBtn.setAttribute('aria-expanded', 'false');
      } else {
        langMenu.classList.remove('hidden');
        langBtn.setAttribute('aria-expanded', 'true');
      }
    });
    document.addEventListener('click', () => {
      langMenu.classList.add('hidden');
      langBtn.setAttribute('aria-expanded', 'false');
    });
  }

  const langLinks = document.querySelectorAll<HTMLAnchorElement>('[data-lang-link]');
  const SECCIONES = ['inicio', 'servicios', 'sobre', 'resenas', 'faqs', 'contacto'];
  let seccionActiva = '';

  function aplicarHashEnLangLinks(hash: string) {
    langLinks.forEach(a => {
      const base = a.getAttribute('href')?.split('#')[0] ?? '';
      a.setAttribute('href', hash ? `${base}${hash}` : base);
    });
  }

  const hashInicial = window.location.hash.replace(/^#/, '');
  if (hashInicial && SECCIONES.includes(hashInicial)) {
    seccionActiva = hashInicial;
    aplicarHashEnLangLinks(`#${hashInicial}`);
  }

  const ratios = new Map<string, number>();
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(e => ratios.set(e.target.id, e.isIntersecting ? e.intersectionRatio : 0));
      let mejorId = '';
      let mejorRatio = 0;
      ratios.forEach((r, id) => {
        if (r > mejorRatio) {
          mejorRatio = r;
          mejorId = id;
        }
      });
      if (mejorRatio > 0 && mejorId !== seccionActiva) {
        seccionActiva = mejorId;
        aplicarHashEnLangLinks(`#${mejorId}`);
      }
    },
    { threshold: [0, 0.25, 0.5, 0.75, 1] }
  );
  SECCIONES.forEach(id => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  window.addEventListener('hashchange', () => {
    const h = window.location.hash.replace(/^#/, '');
    if (h && SECCIONES.includes(h)) {
      seccionActiva = h;
      aplicarHashEnLangLinks(`#${h}`);
    }
  });
</script>
