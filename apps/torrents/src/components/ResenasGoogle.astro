---
import MarcaAgua from '@/components/MarcaAgua.astro';
import type { ResenaGoogle, ResumenResenas, TextosCabecera } from '@/lib/sanity';
import { localizar } from '@/lib/sanity';
import { t, rutaConLocale, resaltarTitulo, type Locale } from '@/lib/i18n';

export interface Props {
  resumen: ResumenResenas;
  logo?: string;
  lang: Locale;
  urlGoogleMaps?: string;
  textos?: TextosCabecera;
}

const { resumen, logo, lang, urlGoogleMaps, textos } = Astro.props;

// Hasta 12 reseñas en el marquee: primero destacadas, luego recientes, deduplicado.
const vistos = new Set<string>();
const tarjetas: ResenaGoogle[] = [];
for (const r of [...resumen.destacadas, ...resumen.recientes]) {
  if (vistos.has(r._id)) continue;
  vistos.add(r._id);
  tarjetas.push(r);
  if (tarjetas.length >= 12) break;
}

const mostrar = tarjetas.length > 0;
const mediaFormateada = resumen.media > 0 ? resumen.media.toFixed(1) : '—';

// Partimos en dos filas alternando para distribuir destacadas y largos.
const fila1: ResenaGoogle[] = [];
const fila2: ResenaGoogle[] = [];
tarjetas.forEach((r, i) => (i % 2 === 0 ? fila1.push(r) : fila2.push(r)));

// Duplicamos cada fila para conseguir loop infinito sin saltos visibles.
const fila1Duplicada = [...fila1, ...fila1];
const fila2Duplicada = [...fila2, ...fila2];

function relativo(fechaIso: string): string {
  const ahora = Date.now();
  const fecha = new Date(fechaIso).getTime();
  const diff = Math.max(0, ahora - fecha);
  const dia = 1000 * 60 * 60 * 24;
  const dias = Math.round(diff / dia);
  if (dias < 1) return t('resenas.hace.ahora', lang);
  if (dias < 14) return t(dias === 1 ? 'resenas.hace.diasUno' : 'resenas.hace.diasN', lang, { n: dias });
  const semanas = Math.round(dias / 7);
  if (dias < 60) return t(semanas === 1 ? 'resenas.hace.semanasUno' : 'resenas.hace.semanasN', lang, { n: semanas });
  const meses = Math.round(dias / 30);
  if (dias < 365) return t(meses === 1 ? 'resenas.hace.mesesUno' : 'resenas.hace.mesesN', lang, { n: meses });
  const anyos = Math.round(dias / 365);
  return t(anyos === 1 ? 'resenas.hace.anyosUno' : 'resenas.hace.anyosN', lang, { n: anyos });
}

function inicial(nombre?: string): string {
  if (!nombre) return '?';
  const c = nombre.trim()[0];
  return c ? c.toUpperCase() : '?';
}

const chip = localizar(textos?.chip, lang) ?? t('resenas.chip', lang);
const tituloTexto = localizar(textos?.titulo, lang) ?? t('resenas.titulo', lang);
const { inicio: tituloParte1, resaltado: tituloParte2 } = resaltarTitulo(tituloTexto);
const subtitulo =
  localizar(textos?.subtitulo, lang) ??
  (resumen.total > 0
    ? t('resenas.subtitulo', lang, { total: resumen.total, media: mediaFormateada })
    : t('resenas.subtituloSinNumero', lang));

const verTodasHref = rutaConLocale('/resenas', lang);
---

{
  mostrar && (
    <section id='resenas' class='relative overflow-hidden py-24'>
      <MarcaAgua logo={logo} class='top-20 right-6 md:right-16' tamano={68} opacidad={0.05} rotacion={-12} />
      <MarcaAgua logo={logo} class='bottom-16 left-6 md:left-16' tamano={60} opacidad={0.05} rotacion={14} />

      <div class='container-app relative'>
        <div class='mb-10 text-start md:mb-14 md:text-center'>
          <div class='chip mb-6'>
            <svg width='14' height='14' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
              <path d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' />
            </svg>
            {chip}
          </div>
          <h2 class='mb-4 text-3xl font-bold tracking-tight md:text-4xl'>
            {tituloParte1 && <>{tituloParte1}{' '}</>}
            <span class='text-primary'>{tituloParte2}</span>
          </h2>
          <p class='text-muted-foreground mx-auto max-w-2xl'>{subtitulo}</p>
        </div>
      </div>

      {/* ── Versión móvil: scroll horizontal con snap, sin animación ─────── */}
      <div class='resenas-mobile' aria-label={t('resenas.ariaSlider', lang)}>
        <ul class='resenas-mobile__pista'>
          {tarjetas.map((r) => {
            const estrellas = Math.max(0, Math.min(5, r.rating ?? 0));
            return (
              <li class='resenas-mobile__item'>
                <article class={`resena ${r.destacada ? 'resena--destacada' : ''}`}>
                  <header class='resena__head'>
                    {r.autorFotoUrl ? (
                      <img src={r.autorFotoUrl} alt='' loading='lazy' referrerpolicy='no-referrer' class='resena__avatar' />
                    ) : (
                      <span class='resena__avatar resena__avatar--inicial' aria-hidden='true'>
                        {inicial(r.autorNombre)}
                      </span>
                    )}
                    <div class='resena__meta'>
                      <p class='resena__autor'>{r.autorNombre ?? t('resenas.anonimo', lang)}</p>
                      <time datetime={r.fechaPublicacion} class='resena__fecha'>{relativo(r.fechaPublicacion)}</time>
                    </div>
                    <div class='resena__estrellas' role='img' aria-label={t('resenas.ariaEstrellas', lang, { rating: estrellas })}>
                      {Array.from({ length: 5 }).map((_, j) => (
                        <svg width='14' height='14' viewBox='0 0 24 24' fill={j < estrellas ? 'currentColor' : 'none'} stroke='currentColor' stroke-width='2' stroke-linejoin='round' aria-hidden='true'>
                          <path d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' />
                        </svg>
                      ))}
                    </div>
                  </header>
                  {r.comentario && <p class='resena__texto'>{r.comentario}</p>}
                </article>
              </li>
            );
          })}
        </ul>
      </div>

      {/* ── Versión desktop: marquee infinito 2 filas ────────────────────── */}
      <div class='resenas-marquee' aria-label={t('resenas.ariaSlider', lang)}>
        {fila1.length > 0 && (
          <div class='resenas-marquee__fila' data-fila='1'>
            <ul class='resenas-marquee__pista' aria-hidden='false'>
              {fila1Duplicada.map((r, i) => {
                const estrellas = Math.max(0, Math.min(5, r.rating ?? 0));
                const esClon = i >= fila1.length;
                return (
                  <li class='resenas-marquee__item' aria-hidden={esClon ? 'true' : 'false'}>
                    <article class={`resena ${r.destacada ? 'resena--destacada' : ''}`}>
                      <header class='resena__head'>
                        {r.autorFotoUrl ? (
                          <img src={r.autorFotoUrl} alt='' loading='lazy' referrerpolicy='no-referrer' class='resena__avatar' />
                        ) : (
                          <span class='resena__avatar resena__avatar--inicial' aria-hidden='true'>
                            {inicial(r.autorNombre)}
                          </span>
                        )}
                        <div class='resena__meta'>
                          <p class='resena__autor'>{r.autorNombre ?? t('resenas.anonimo', lang)}</p>
                          <time datetime={r.fechaPublicacion} class='resena__fecha'>{relativo(r.fechaPublicacion)}</time>
                        </div>
                        <div class='resena__estrellas' role='img' aria-label={t('resenas.ariaEstrellas', lang, { rating: estrellas })}>
                          {Array.from({ length: 5 }).map((_, j) => (
                            <svg width='14' height='14' viewBox='0 0 24 24' fill={j < estrellas ? 'currentColor' : 'none'} stroke='currentColor' stroke-width='2' stroke-linejoin='round' aria-hidden='true'>
                              <path d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' />
                            </svg>
                          ))}
                        </div>
                      </header>
                      {r.comentario && <p class='resena__texto'>{r.comentario}</p>}
                    </article>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {fila2.length > 0 && (
          <div class='resenas-marquee__fila' data-fila='2'>
            <ul class='resenas-marquee__pista' aria-hidden='false'>
              {fila2Duplicada.map((r, i) => {
                const estrellas = Math.max(0, Math.min(5, r.rating ?? 0));
                const esClon = i >= fila2.length;
                return (
                  <li class='resenas-marquee__item' aria-hidden={esClon ? 'true' : 'false'}>
                    <article class={`resena ${r.destacada ? 'resena--destacada' : ''}`}>
                      <header class='resena__head'>
                        {r.autorFotoUrl ? (
                          <img src={r.autorFotoUrl} alt='' loading='lazy' referrerpolicy='no-referrer' class='resena__avatar' />
                        ) : (
                          <span class='resena__avatar resena__avatar--inicial' aria-hidden='true'>
                            {inicial(r.autorNombre)}
                          </span>
                        )}
                        <div class='resena__meta'>
                          <p class='resena__autor'>{r.autorNombre ?? t('resenas.anonimo', lang)}</p>
                          <time datetime={r.fechaPublicacion} class='resena__fecha'>{relativo(r.fechaPublicacion)}</time>
                        </div>
                        <div class='resena__estrellas' role='img' aria-label={t('resenas.ariaEstrellas', lang, { rating: estrellas })}>
                          {Array.from({ length: 5 }).map((_, j) => (
                            <svg width='14' height='14' viewBox='0 0 24 24' fill={j < estrellas ? 'currentColor' : 'none'} stroke='currentColor' stroke-width='2' stroke-linejoin='round' aria-hidden='true'>
                              <path d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' />
                            </svg>
                          ))}
                        </div>
                      </header>
                      {r.comentario && <p class='resena__texto'>{r.comentario}</p>}
                    </article>
                  </li>
                );
              })}
            </ul>
          </div>
        )}
      </div>

      <div class='container-app relative'>
        <div class='mt-12 flex flex-wrap items-center justify-center gap-4'>
          <a
            href={verTodasHref}
            class='inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-sm transition hover:shadow-md hover:-translate-y-0.5'
          >
            {t('resenas.verTodas', lang)}
            <svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
              <path d='M5 12h14M13 5l7 7-7 7' />
            </svg>
          </a>
          {urlGoogleMaps && (
            <a
              href={urlGoogleMaps}
              target='_blank'
              rel='noopener noreferrer'
              class='inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline'
            >
              {t('resenas.verEnGoogle', lang)}
              <svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
                <path d='M7 17L17 7M9 7h8v8' />
              </svg>
            </a>
          )}
        </div>
      </div>
    </section>
  )
}

<style>
  /* ── Mobile: snap-scroll horizontal, sin animación ───────────────────── */
  .resenas-mobile {
    display: block;
    /* Padding lateral mantiene el "peek" de la siguiente card al borde */
    padding-inline: 1rem;
  }
  .resenas-mobile__pista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.85rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 1rem;
    /* Padding interno para que la primera y última card respiren */
    padding-inline: 0.25rem;
    /* Ocultar scrollbar visual (mantiene scroll funcional) */
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
  }
  .resenas-mobile__pista::-webkit-scrollbar { display: none; }

  .resenas-mobile__item {
    flex: 0 0 min(85vw, 320px);
    scroll-snap-align: center;
    display: flex;
  }
  .resenas-mobile__item > .resena {
    width: 100%;
  }

  @media (min-width: 768px) {
    .resenas-mobile { display: none; }
  }

  /* ── Desktop: marquee infinito 2 filas ───────────────────────────────── */
  .resenas-marquee {
    --duracion-1: 60s;
    --duracion-2: 75s;
    --gap: 1.25rem;
    display: none;
    flex-direction: column;
    gap: var(--gap);
    /* Fade en los bordes laterales para que las cards "aparezcan" suavemente */
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
            mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }
  @media (min-width: 768px) {
    .resenas-marquee { display: flex; }
  }

  .resenas-marquee__fila {
    overflow: hidden;
  }

  .resenas-marquee__pista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--gap);
    width: max-content;
    will-change: transform;
  }

  /* Dirección y velocidad distintas por fila */
  .resenas-marquee__fila[data-fila='1'] .resenas-marquee__pista {
    animation: marquee-izq var(--duracion-1) linear infinite;
  }
  .resenas-marquee__fila[data-fila='2'] .resenas-marquee__pista {
    animation: marquee-der var(--duracion-2) linear infinite;
  }

  @keyframes marquee-izq {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes marquee-der {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* Pausa al hover/focus dentro del marquee */
  .resenas-marquee:hover .resenas-marquee__pista,
  .resenas-marquee:focus-within .resenas-marquee__pista {
    animation-play-state: paused;
  }

  /* Respeta prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .resenas-marquee__pista {
      animation: none !important;
      transform: none !important;
    }
    .resenas-marquee__fila {
      overflow-x: auto;
    }
  }

  .resenas-marquee__item {
    flex: 0 0 320px;
    display: flex;
  }
  .resenas-marquee__item > .resena {
    width: 100%;
  }
  @media (max-width: 640px) {
    .resenas-marquee__item {
      flex-basis: 280px;
    }
    .resenas-marquee {
      --gap: 0.85rem;
    }
  }

  /* Card */
  .resena {
    background: var(--card, #fff);
    border: 1px solid var(--border, #e5e7eb);
    border-radius: 16px;
    padding: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
  }
  .resena--destacada {
    border-color: color-mix(in srgb, var(--primary, #0d6e6e) 45%, transparent);
    background: linear-gradient(180deg, color-mix(in srgb, var(--primary, #0d6e6e) 6%, transparent), transparent 70%);
  }

  .resena__head {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 0.7rem;
    align-items: center;
    margin-bottom: 0.9rem;
  }
  .resena__avatar {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    object-fit: cover;
    background: #f1f5f9;
  }
  .resena__avatar--inicial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--primary, #0d6e6e);
    color: white;
    font-weight: 700;
    font-size: 1rem;
  }
  .resena__meta { min-width: 0; }
  .resena__autor {
    margin: 0;
    font-weight: 600;
    color: #0f172a;
    font-size: 0.95rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .resena__fecha {
    font-size: 0.78rem;
    color: #64748b;
  }
  .resena__estrellas {
    color: #f59e0b;
    display: inline-flex;
    gap: 1px;
  }
  .resena__texto {
    margin: 0;
    color: #334155;
    font-size: 0.92rem;
    line-height: 1.55;
    /* Limita a 6 líneas para que las cards mantengan altura razonable en el marquee */
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
