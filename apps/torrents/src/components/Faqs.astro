---
import MarcaAgua from '@/components/MarcaAgua.astro';
import type { Faq, TextosCabecera } from '@/lib/sanity';
import { localizar } from '@/lib/sanity';
import { t, resaltarTitulo, type Locale } from '@/lib/i18n';

export interface Props {
  faqs?: Faq[];
  logo?: string;
  lang: Locale;
  /** Textos editables de la cabecera. Si están vacíos, cae a i18n. */
  textos?: TextosCabecera;
}

const { faqs = [], logo, lang, textos } = Astro.props;

const lista = faqs
  .map(f => ({
    pregunta: localizar(f.pregunta, lang),
    respuesta: localizar(f.respuesta, lang)
  }))
  .filter((f): f is { pregunta: string; respuesta: string } => Boolean(f.pregunta && f.respuesta));

const chip = localizar(textos?.chip, lang) ?? t('faqs.chip', lang);
const tituloTexto = localizar(textos?.titulo, lang) ?? t('faqs.titulo', lang);
const { inicio: tituloParte1, resaltado: tituloParte2 } = resaltarTitulo(tituloTexto);
const subtitulo = localizar(textos?.subtitulo, lang) ?? t('faqs.subtitulo', lang);
---

{
  lista.length > 0 && (
    <section id='faqs' class='relative overflow-hidden py-24'>
      <MarcaAgua
        logo={logo}
        class='top-20 right-6 md:right-16'
        tamano={68}
        opacidad={0.05}
        rotacion={-12}
      />
      <MarcaAgua
        logo={logo}
        class='bottom-16 left-6 md:left-16'
        tamano={60}
        opacidad={0.05}
        rotacion={14}
      />
      <MarcaAgua
        logo={logo}
        class='top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2'
        tamano={120}
        opacidad={0.04}
        rotacion={6}
      />

      <div class='container-app relative'>
        <div class='mb-12 text-start md:mb-16 md:text-center'>
          <div class='chip mb-6'>
            <svg
              width='14'
              height='14'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.4'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
              class='text-[var(--primary)]'
            >
              <circle cx='12' cy='12' r='10' />
              <path d='M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3' />
              <line x1='12' y1='17' x2='12.01' y2='17' />
            </svg>
            <span>{chip}</span>
          </div>
          <h2 class='text-4xl font-extrabold tracking-tight md:text-balance md:text-5xl'>
            {tituloParte1 && <>{tituloParte1}{' '}</>}
            <span class='text-[var(--primary)]'>{tituloParte2}</span>
          </h2>
          <p class='mt-4 max-w-2xl text-lg text-[var(--muted-foreground)] md:mx-auto'>
            {subtitulo}
          </p>
        </div>

        <ul class='mx-auto max-w-3xl space-y-3' data-faqs>
          {lista.map((f, i) => (
            <li>
              <details
                class='faq-item group relative overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--card)] transition-all duration-300 hover:border-[color-mix(in_oklch,var(--primary),transparent_70%)] open:border-[color-mix(in_oklch,var(--primary),transparent_55%)] open:shadow-[0_8px_30px_-12px_color-mix(in_oklch,var(--primary),transparent_75%)]'
                data-faq
              >
                <span
                  class='absolute top-0 bottom-0 left-0 w-1 origin-top scale-y-0 rounded-r-full bg-[var(--primary)] transition-transform duration-300 group-open:scale-y-100'
                  aria-hidden='true'
                />

                <summary class='flex cursor-pointer list-none items-center gap-4 px-5 py-5 font-extrabold text-[var(--foreground)] sm:px-6'>
                  <span
                    class='flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[color-mix(in_oklch,var(--primary),transparent_88%)] text-sm font-extrabold tabular-nums text-[var(--primary)] transition-colors duration-300 group-open:bg-[var(--primary)] group-open:text-white'
                    aria-hidden='true'
                  >
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class='flex-1 text-base sm:text-lg'>{f.pregunta}</span>
                  <span
                    class='flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[color-mix(in_oklch,var(--primary),transparent_92%)] text-[var(--primary)] transition-all duration-300 group-open:rotate-45 group-open:bg-[var(--primary)] group-open:text-white'
                    aria-hidden='true'
                  >
                    <svg
                      width='16'
                      height='16'
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='2.6'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                    >
                      <line x1='12' y1='5' x2='12' y2='19' />
                      <line x1='5' y1='12' x2='19' y2='12' />
                    </svg>
                  </span>
                </summary>

                <div class='faq-contenido' data-faq-contenido>
                  <div class='px-5 pb-5 sm:px-6'>
                    <div class='border-t border-[color-mix(in_oklch,var(--border),transparent_40%)] pt-4 pl-13'>
                      <p class='leading-relaxed whitespace-pre-line text-[var(--muted-foreground)]'>
                        {f.respuesta}
                      </p>
                    </div>
                  </div>
                </div>
              </details>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}

<style>
  .faq-item > summary::-webkit-details-marker,
  .faq-item > summary::marker {
    display: none;
    content: '';
  }

  .faq-contenido {
    overflow: hidden;
    transition: height 350ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .faq-item:not([open]) .faq-contenido {
    height: 0;
  }

  .pl-13 {
    padding-left: 3.25rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-contenido {
      transition: none;
    }
  }
</style>

<script>
  function inicializarFaqs() {
    const items = document.querySelectorAll<HTMLDetailsElement>('[data-faq]');

    items.forEach(item => {
      if (item.dataset.faqInit === '1') return;
      item.dataset.faqInit = '1';

      const summary = item.querySelector<HTMLElement>('summary');
      const contenido = item.querySelector<HTMLElement>('[data-faq-contenido]');
      if (!summary || !contenido) return;

      summary.addEventListener('click', evento => {
        evento.preventDefault();

        if (item.open) {
          cerrar(item, contenido);
        } else {
          abrir(item, contenido);
        }
      });
    });

    function abrir(item: HTMLDetailsElement, contenido: HTMLElement) {
      item.open = true;
      const altura = contenido.scrollHeight;
      contenido.style.height = '0px';
      requestAnimationFrame(() => {
        contenido.style.height = altura + 'px';
      });
      contenido.addEventListener(
        'transitionend',
        () => {
          contenido.style.height = 'auto';
        },
        { once: true }
      );
    }

    function cerrar(item: HTMLDetailsElement, contenido: HTMLElement) {
      const altura = contenido.scrollHeight;
      contenido.style.height = altura + 'px';
      requestAnimationFrame(() => {
        contenido.style.height = '0px';
      });
      contenido.addEventListener(
        'transitionend',
        () => {
          item.open = false;
          contenido.style.height = '';
        },
        { once: true }
      );
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', inicializarFaqs);
  } else {
    inicializarFaqs();
  }
</script>
