---
import type { Direccion, ImagenConAlt } from '@/lib/sanity';
import { localizar } from '@/lib/sanity';
import { t, type Locale } from '@/lib/i18n';
import Slider from '@/components/Slider.astro';
import MarcaAgua from '@/components/MarcaAgua.astro';

export interface Props {
  nombre: string;
  claim?: string;
  ciudad?: string;
  telefono?: string;
  whatsapp?: string;
  imagenes?: ImagenConAlt[];
  logo?: string;
  direccion?: Direccion;
  lang: Locale;
}

const {
  nombre,
  claim,
  ciudad,
  telefono,
  whatsapp,
  imagenes = [],
  logo,
  direccion,
  lang
} = Astro.props;

const tieneImagenes = imagenes.length > 0;
const limpiarTel = (t?: string) => t?.replace(/\s+/g, '');
const waUrl = whatsapp ? `https://wa.me/${limpiarTel(whatsapp)?.replace(/^\+/, '')}` : null;

const direccionCorta = direccion
  ? [direccion.calle, direccion.ciudad].filter(Boolean).join(', ')
  : null;

const chipTexto = ciudad
  ? t('hero.chip.conCiudad', lang, { ciudad })
  : t('hero.chip.sinCiudad', lang);

const altInterior = t('hero.altInterior', lang, { nombre });
---

<section id='inicio' class='relative flex min-h-[80vh] items-center overflow-hidden pt-16 pb-20'>
  <div class='absolute inset-0 overflow-hidden' aria-hidden='true'>
    <div
      class='absolute top-20 right-10 h-96 w-96 rounded-full bg-[color-mix(in_oklch,var(--primary),transparent_90%)] blur-3xl'
    >
    </div>
    <div
      class='absolute bottom-20 left-10 h-80 w-80 rounded-full bg-[color-mix(in_oklch,var(--accent),transparent_90%)] blur-3xl'
    >
    </div>
    <div
      class='absolute top-1/2 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[color-mix(in_oklch,var(--accent),transparent_90%)] blur-3xl'
    >
    </div>
    <div class='dot-pattern absolute inset-0 opacity-50'></div>
  </div>

  <MarcaAgua
    logo={logo}
    class='bottom-12 right-8 md:right-16'
    tamano={90}
    opacidad={0.05}
    rotacion={-12}
  />
  <MarcaAgua
    logo={logo}
    class='top-1/2 left-4 md:left-1/3 -translate-y-1/2'
    tamano={110}
    opacidad={0.04}
    rotacion={6}
  />
  <MarcaAgua logo={logo} class='top-24 right-1/3' tamano={56} opacidad={0.05} rotacion={20} />

  <div class='container-app relative'>
    <div class='grid items-center gap-12 lg:grid-cols-2'>
      <div class='space-y-7'>
        <div
          class='inline-flex items-center gap-2 rounded-full border border-[color-mix(in_oklch,var(--primary),transparent_80%)] bg-[color-mix(in_oklch,var(--primary),transparent_94%)] px-4 py-1.5 text-xs font-bold tracking-[0.12em] text-[var(--primary)] uppercase'
        >
          <span class='inline-block h-1.5 w-1.5 rounded-full bg-[var(--accent)]'></span>
          <span>{ciudad ? `Farmacia en ${ciudad}` : 'Tu farmacia de confianza'}</span>
        </div>

        <h1
          class='text-5xl leading-[1.05] font-extrabold tracking-tight text-balance md:text-6xl lg:text-7xl'
        >
          {nombre}
          {
            ciudad && (
              <span class='mt-3 block text-2xl font-bold text-[var(--primary)] md:text-3xl lg:text-4xl'>
                {t('hero.ciudad', lang, { ciudad })}
              </span>
            )
          }
        </h1>

        {
          claim && (
            <p class='max-w-md text-lg leading-relaxed text-[var(--muted-foreground)]'>{claim}</p>
          )
        }

        <div class='flex flex-col gap-3 sm:flex-row'>
          {
            waUrl && (
              <a
                href={waUrl}
                target='_blank'
                rel='noopener noreferrer'
                class='btn-wa px-7 py-4 text-base md:text-lg'
              >
                <svg
                  width='20'
                  height='20'
                  viewBox='0 0 24 24'
                  fill='currentColor'
                  aria-hidden='true'
                >
                  <path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488' />
                </svg>
                Escríbenos por WhatsApp
              </a>
            )
          }
          {
            telefono && (
              <a
                href={`tel:${limpiarTel(telefono)}`}
                class='btn-secondary px-7 py-4 text-bae md:text-lg'
              >
                <svg
                  width='18'
                  height='18'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                >
                  <path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z' />
                </svg>
                Llamar ahora
              </a>
            )
          }
        </div>

        {
          direccionCorta && (
            <div class='flex items-start gap-2 pt-2 text-sm text-[var(--muted-foreground)]'>
              <svg
                width='16'
                height='16'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2.2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                class='mt-0.5 shrink-0 text-[var(--primary)]'
              >
                <path d='M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z' />
                <circle cx='12' cy='10' r='3' />
              </svg>
              <span>{direccionCorta}</span>
            </div>
          )
        }
      </div>

      <div class='relative'>
        <div class='relative mx-auto aspect-square max-w-2xl'>
          {
            tieneImagenes ? (
              <div class='absolute inset-4'>
                <Slider
                  imagenes={imagenes.map(img => ({
                    url: img.url,
                    alt: localizar(img.alt, lang)
                  }))}
                  alt={altInterior}
                  ancho={900}
                  prioridad={true}
                  marcaAgua={logo}
                  marcaAguaAlt={nombre}
                />
              </div>
            ) : (
              <div
                class='absolute inset-4 overflow-hidden rounded-[2rem] border bg-[var(--card)] shadow-2xl'
                style='box-shadow: 0 25px 50px -12px color-mix(in oklch, var(--primary), transparent 85%);'
              >
                <div class='flex h-full w-full items-center justify-center'>
                  <div class='relative h-48 w-48'>
                    <div class='absolute inset-0 rounded-full bg-[color-mix(in_oklch,var(--primary),transparent_80%)]' />
                    <div class='absolute inset-4 rounded-full bg-[color-mix(in_oklch,var(--primary),transparent_60%)]' />
                    <div class='absolute inset-8 flex items-center justify-center rounded-full bg-[var(--primary)] shadow-lg'>
                      <span class='text-6xl font-extrabold text-white'>+</span>
                    </div>
                  </div>
                </div>
              </div>
            )
          }

          <div
            class='absolute z-10 -top-4 -right-4 rounded-2xl border bg-[var(--card)] p-4 shadow-xl'
          >
            <div class='flex items-center gap-3'>
              <div
                class='flex h-12 w-12 items-center justify-center rounded-xl bg-[color-mix(in_oklch,var(--kids-green),transparent_80%)]'
              >
                <svg
                  width='22'
                  height='22'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  style='color: var(--kids-green);'
                  aria-hidden='true'
                >
                  <path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'></path>
                </svg>
              </div>
              <div>
                <div class='font-extrabold'>Productos seguros</div>
                <div class='text-sm text-[var(--muted-foreground)]'>Para tu bebé</div>
              </div>
            </div>
          </div>

          <div
            class='absolute z-10 -bottom-4 -left-4 rounded-2xl border bg-[var(--card)] p-4 shadow-xl'
          >
            <div class='flex items-center gap-3'>
              <div
                class='flex h-12 w-12 items-center justify-center rounded-xl bg-[color-mix(in_oklch,var(--accent),transparent_80%)]'
              >
                <svg
                  width='22'
                  height='22'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  class='text-[var(--accent)]'
                  aria-hidden='true'
                >
                  <path d='M11 2v8a4 4 0 0 1-4 4 4 4 0 0 1-4-4V2M6 2v8M11 2V2'></path>
                  <path d='M19 14v6a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2v-6a4 4 0 0 1 4-4 4 4 0 0 1 4 4z'>
                  </path>
                </svg>
              </div>
              <div>
                <div class='font-extrabold'>Atención profesional</div>
                <div class='text-sm text-[var(--muted-foreground)]'>Farmacéuticos pediátricos</div>
              </div>
            </div>
          </div>

          <div
            class='absolute z-10 top-1/2 -left-8 hidden rounded-2xl border bg-[var(--card)] p-4 shadow-xl md:block'
          >
            <div class='flex items-center gap-3'>
              <div
                class='flex h-12 w-12 items-center justify-center rounded-xl bg-[color-mix(in_oklch,var(--kids-yellow),transparent_75%)]'
              >
                <svg
                  width='22'
                  height='22'
                  viewBox='0 0 24 24'
                  fill='currentColor'
                  style='color: var(--kids-orange);'
                  aria-hidden='true'
                >
                  <polygon
                    points='12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2'
                  >
                  </polygon>
                </svg>
              </div>
              <div>
                <div class='font-extrabold'>Calidad garantizada</div>
                <div class='text-sm text-[var(--muted-foreground)]'>Marcas de confianza</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
