---
import MarcaAgua from '@/components/MarcaAgua.astro';
import IconoServicio from '@/components/IconoServicio.astro';
import type { FeatureItem, IconoNombre } from '@/lib/sanity';
import { localizar } from '@/lib/sanity';
import { t, type Locale } from '@/lib/i18n';

interface FeatureRender {
  icono: IconoNombre;
  titulo: string;
  descripcion: string;
}

export interface Props {
  horarioTexto?: string;
  logo?: string;
  lang: Locale;
  /**
   * Lista editable desde Sanity. Si está vacía, se renderizan las 4 features
   * de fábrica (atención, calidad, equipo, horario) traducidas con i18n.
   *
   * Caso especial: una feature con `icono === 'clock'` y descripción vacía cae
   * al horario auto-calculado (`horarioTexto`).
   */
  lista?: FeatureItem[];
}

const { horarioTexto, logo, lang, lista } = Astro.props;

function defectoSiVacio(items: FeatureItem[] | undefined, fallback: FeatureRender[]): FeatureRender[] {
  if (!items || items.length === 0) return fallback;
  return items
    .map((it) => {
      const titulo = localizar(it.titulo, lang);
      const descLocalizada = localizar(it.descripcion, lang);
      const icono = (it.icono ?? 'heart') as IconoNombre;
      const descripcion =
        descLocalizada ||
        (icono === 'clock' ? horarioTexto ?? t('features.horarioDescFallback', lang) : '');
      if (!titulo) return null;
      return { icono, titulo, descripcion };
    })
    .filter((f): f is FeatureRender => f !== null);
}

const featuresFallback: FeatureRender[] = [
  {
    icono: 'heart',
    titulo: t('features.atencionTitulo', lang),
    descripcion: t('features.atencionDesc', lang),
  },
  {
    icono: 'award',
    titulo: t('features.calidadTitulo', lang),
    descripcion: t('features.calidadDesc', lang),
  },
  {
    icono: 'users',
    titulo: t('features.equipoTitulo', lang),
    descripcion: t('features.equipoDesc', lang),
  },
  {
    icono: 'clock',
    titulo: t('features.horarioTitulo', lang),
    descripcion: horarioTexto ?? t('features.horarioDescFallback', lang),
  },
];

const features = defectoSiVacio(lista, featuresFallback);
---

<section
  class='relative overflow-hidden border-y border-[var(--border)] bg-[var(--card)] py-12 md:py-16'
>
  <MarcaAgua
    logo={logo}
    class='top-4 right-6 md:right-12'
    tamano={56}
    opacidad={0.05}
    rotacion={10}
  />
  <MarcaAgua
    logo={logo}
    class='bottom-4 left-6 md:left-12'
    tamano={52}
    opacidad={0.05}
    rotacion={-8}
  />
  <MarcaAgua
    logo={logo}
    class='top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2'
    tamano={68}
    opacidad={0.04}
    rotacion={0}
  />
  <div class='container-app relative'>
    <div class='grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-4 md:gap-8'>
      {
        features.map(f => (
          <div class='flex items-center gap-4'>
            <div class='flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[color-mix(in_oklch,var(--primary),transparent_90%)] text-[var(--primary)]'>
              <IconoServicio nombre={f.icono} size={28} />
            </div>
            <div class='min-w-0'>
              <h3 class='font-extrabold'>{f.titulo}</h3>
              {f.descripcion && (
                <p class='m-0 text-sm text-[var(--muted-foreground)]'>{f.descripcion}</p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
