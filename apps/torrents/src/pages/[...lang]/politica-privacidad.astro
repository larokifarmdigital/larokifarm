---
// TODO i18n legal: el texto legal está en español en todas las locales hasta revisión jurídica.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import {
  obtenerFarmaciaPorSlug,
  agruparHorarios,
  localizar,
  SLUG_FARMACIA,
  type Farmacia,
  type DiasI18n,
} from '@/lib/sanity';
import {
  esLocaleValido,
  rutaConLocale,
  t,
  type Locale,
} from '@/lib/i18n';
import diasEs from '@/i18n/es.json';
import diasEn from '@/i18n/en.json';
import diasCa from '@/i18n/ca.json';

export async function getStaticPaths() {
  const farmacia = await obtenerFarmaciaPorSlug(SLUG_FARMACIA);
  const codigos = (farmacia?.idiomasActivos ?? [{ codigo: 'es', nombre: 'Español' }])
    .map((i) => i.codigo)
    .filter(esLocaleValido);
  const lista = codigos.length > 0 ? codigos : (['es'] as Locale[]);
  return lista.map((c) => ({
    params: { lang: c === 'es' ? undefined : c },
    props: { farmacia, lang: c },
  }));
}

interface Props { farmacia: Farmacia | null; lang: Locale; }
const { farmacia: farmaciaCargada, lang } = Astro.props as Props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const farmacia: Farmacia = farmaciaCargada ?? {
  _id: 'placeholder',
  nombre: 'Farmacia Torrents',
  slug: SLUG_FARMACIA,
};

const DIAS_POR_LANG: Record<Locale, DiasI18n> = {
  es: diasEs.dias as DiasI18n,
  en: diasEn.dias as DiasI18n,
  ca: diasCa.dias as DiasI18n,
};
const CERRADO_LABEL: Record<Locale, string> = {
  es: 'Cerrado', en: 'Closed', ca: 'Tancat',
};
const horariosAgrupados = agruparHorarios(
  farmacia.horarios,
  DIAS_POR_LANG[lang],
  CERRADO_LABEL[lang],
);
const mostrarFaqs = (farmacia.faqs ?? []).some(
  (f) => localizar(f.pregunta, lang) && localizar(f.respuesta, lang),
);

const direccionCompleta = [
  farmacia.direccion?.calle,
  farmacia.direccion?.codigoPostal,
  farmacia.direccion?.ciudad,
  farmacia.direccion?.provincia,
]
  .filter(Boolean)
  .join(', ');

const anyo = new Date().getFullYear();
const canonical = `${siteUrl}${rutaConLocale('/politica-privacidad', lang)}`;
const home = rutaConLocale('/', lang);
---

<BaseLayout
  titulo={`Política de privacidad · ${farmacia.nombre}`}
  descripcion={`Política de privacidad y tratamiento de datos personales de ${farmacia.nombre}.`}
  canonical={canonical}
  lang={lang}
  rutaActual='/politica-privacidad'
>
  <Header
    nombre={farmacia.nombre}
    whatsapp={farmacia.contacto?.whatsapp}
    telefono={farmacia.contacto?.telefono}
    logo={farmacia.logo}
    mostrarFaqs={mostrarFaqs}
    lang={lang}
    rutaActual='/politica-privacidad'
    idiomasActivos={farmacia.idiomasActivos}
  />

  <main id='contenido' class='container-app py-16 md:py-24'>
    <article class='prose-legal mx-auto max-w-3xl space-y-6'>
      <a href={home} class='inline-flex items-center gap-2 text-sm text-[var(--muted-foreground)] hover:text-[var(--primary)]'>
        <svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
          <path d='m15 18-6-6 6-6' />
        </svg>
        {t('legal.volver', lang)}
      </a>

      <h1 class='text-4xl font-extrabold tracking-tight md:text-5xl'>Política de privacidad</h1>

      <p class='text-sm text-[var(--muted-foreground)]'>Última actualización: {anyo}</p>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>1. Responsable del tratamiento</h2>
        <p>
          De acuerdo con el Reglamento (UE) 2016/679 General de Protección de Datos (RGPD) y la Ley
          Orgánica 3/2018 de Protección de Datos Personales y garantía de los derechos digitales
          (LOPDGDD), el responsable del tratamiento de los datos personales recabados a través de este
          sitio web es:
        </p>
        <ul class='ml-5 list-disc space-y-1'>
          <li><strong>Denominación:</strong> {farmacia.nombre}</li>
          {farmacia.titular && <li><strong>Farmacéutico/a titular:</strong> {farmacia.titular}</li>}
          {direccionCompleta && <li><strong>Dirección:</strong> {direccionCompleta}</li>}
          {farmacia.contacto?.email && <li><strong>Email:</strong> {farmacia.contacto.email}</li>}
          {farmacia.contacto?.telefono && <li><strong>Teléfono:</strong> {farmacia.contacto.telefono}</li>}
        </ul>
      </section>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>2. Datos personales que tratamos</h2>
        <p>
          Este sitio web es informativo y <strong>no dispone de formularios de registro ni de compra
          online</strong>. Los únicos datos personales que podríamos llegar a tratar son los que el
          usuario nos facilite de forma voluntaria al contactarnos por:
        </p>
        <ul class='ml-5 list-disc space-y-1'>
          <li>WhatsApp (el número del usuario y el contenido del mensaje).</li>
          <li>Llamada telefónica (los datos que el usuario decida compartir).</li>
          <li>Correo electrónico (dirección y contenido del mensaje).</li>
        </ul>
      </section>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>3. Finalidad y base legal</h2>
        <p>
          Los datos se tratarán únicamente para atender la consulta o solicitud del usuario. La base
          legal del tratamiento es el consentimiento del interesado, que se entiende otorgado al iniciar
          el contacto por su propia iniciativa (art. 6.1.a RGPD).
        </p>
        <p>
          No se realizan tratamientos basados en decisiones automatizadas ni se elaboran perfiles.
        </p>
      </section>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>4. Conservación de los datos</h2>
        <p>
          Los datos se conservarán durante el tiempo necesario para atender la consulta y, posteriormente,
          durante el plazo legalmente exigible para atender posibles responsabilidades. Una vez
          finalizado dicho plazo, los datos serán eliminados.
        </p>
      </section>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>5. Destinatarios y cesiones</h2>
        <p>
          No se cederán los datos a terceros, salvo obligación legal. Determinados servicios externos
          que usamos para que la web funcione (por ejemplo Google Maps al cargar el mapa, o WhatsApp al
          pulsar en el botón de WhatsApp) pueden recabar datos por su cuenta, conforme a sus propias
          políticas de privacidad.
        </p>
      </section>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>6. Derechos del usuario</h2>
        <p>
          El usuario puede ejercer en cualquier momento los siguientes derechos sobre sus datos
          personales: acceso, rectificación, supresión, oposición, limitación del tratamiento y
          portabilidad. También puede retirar el consentimiento prestado.
        </p>
        <p>
          Para ejercerlos, basta con enviar una solicitud por correo electrónico
          {farmacia.contacto?.email && (
            <>
              {' '}a <a href={`mailto:${farmacia.contacto.email}`} class='text-[var(--primary)] underline'>{farmacia.contacto.email}</a>
            </>
          )}
          {!farmacia.contacto?.email && ' a la dirección de contacto indicada en el aviso legal'}
          , adjuntando copia de un documento que acredite su identidad.
        </p>
        <p>
          Si considera que el tratamiento de sus datos no se ajusta a la normativa, puede presentar una
          reclamación ante la <strong>Agencia Española de Protección de Datos</strong>
          (<a href='https://www.aepd.es' target='_blank' rel='noopener noreferrer' class='text-[var(--primary)] underline'>www.aepd.es</a>).
        </p>
      </section>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>7. Cookies y servicios de terceros</h2>
        <p>
          Esta web <strong>no instala cookies de seguimiento ni de publicidad</strong>. Únicamente se
          cargan recursos externos imprescindibles para mostrar el contenido (por ejemplo, Google Maps
          para el mapa de localización o fuentes tipográficas alojadas en Google Fonts). Estos servicios
          pueden recabar información de forma autónoma, sujetos a sus propias políticas.
        </p>
        <p class='text-sm text-[var(--muted-foreground)]'>
          <em>
            Si en el futuro se añade un sistema de analítica (por ejemplo Plausible, GA4) o cualquier
            cookie no estrictamente necesaria, esta política se actualizará y se mostrará el banner de
            consentimiento correspondiente.
          </em>
        </p>
      </section>

      <section class='space-y-3'>
        <h2 class='text-2xl font-extrabold'>8. Cambios en la política de privacidad</h2>
        <p>
          {farmacia.nombre} se reserva el derecho a modificar esta política para adaptarla a novedades
          legislativas o a sus propios criterios. Cualquier cambio se publicará en esta misma página y
          surtirá efecto desde su publicación.
        </p>
      </section>
    </article>
  </main>

  <Footer
    nombre={farmacia.nombre}
    titular={farmacia.titular}
    numeroColegiado={farmacia.numeroColegiado}
    logo={farmacia.logo}
    contacto={farmacia.contacto}
    redes={farmacia.redesSociales}
    direccion={farmacia.direccion}
    horarios={farmacia.horarios}
    horariosAgrupados={horariosAgrupados}
    servicios={farmacia.servicios}
    descripcionCorta={farmacia.descripcionCorta}
    mostrarFaqs={mostrarFaqs}
    lang={lang}
    rutaActual='/politica-privacidad'
  />
</BaseLayout>

<style>
  .prose-legal h2 {
    margin-top: 1.5rem;
  }
  .prose-legal p,
  .prose-legal li {
    line-height: 1.7;
    color: color-mix(in oklch, var(--foreground), transparent 15%);
  }
  .prose-legal a {
    word-break: break-word;
  }
</style>
