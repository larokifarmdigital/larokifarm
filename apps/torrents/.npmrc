# Mitigación de ataques de supply chain en npm.
# No instalar versiones publicadas hace menos de 3 días (4320 minutos).
# La mayoría de paquetes maliciosos se retiran del registro en horas.
minimum-release-age=4320

# Excepciones: paquetes muy auditados que han bloqueado un install legítimo.
minimum-release-age-exclude[]=yaml
minimum-release-age-exclude[]=@types/node
