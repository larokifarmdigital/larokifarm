---
import { listarFarmaciasPartner } from '@larokifarm/calendario-vacunas';
import { LOCALE_DEFECTO, rutaConLocale, t, type Locale } from '@/lib/i18n';

interface Props {
  lang?: Locale;
  rutaActual?: string;
}

const { lang = LOCALE_DEFECTO } = Astro.props;

const partners = await listarFarmaciasPartner();
const totalPartners = partners.length;
const anyo = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <section class="about">
        <a href={rutaConLocale('/', lang)} class="brand">{t('brand', lang)}</a>
        <p class="tag">{t('footer.tag', lang)}</p>
      </section>

      <section>
        <h3>{t('footer.recursos', lang)}</h3>
        <ul>
          <li><a href={rutaConLocale('/', lang)}>{t('footer.calendariosCcaa', lang)}</a></li>
          <li><a href={rutaConLocale('/fuentes', lang)}>{t('footer.fuentesOficiales', lang)}</a></li>
          <li>
            <a href={rutaConLocale('/farmacias', lang)}>
              {t('footer.farmaciasAsociadas', lang)}
              {totalPartners > 0 && <span class="count">{totalPartners}</span>}
            </a>
          </li>
        </ul>
      </section>

      <section>
        <h3>{t('footer.legal', lang)}</h3>
        <ul>
          <li><a href={rutaConLocale('/aviso-legal', lang)}>{t('footer.avisoLegal', lang)}</a></li>
          <li><a href={rutaConLocale('/politica-privacidad', lang)}>{t('footer.politicaPrivacidad', lang)}</a></li>
        </ul>
      </section>
    </div>

    <div class="bottom">
      <p>{t('footer.copyright', lang, { anyo })}</p>
      <p class="muted">{t('footer.disclaimer', lang)}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    background: #0f172a;
    color: #cbd5e1;
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3.5rem 1.25rem 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
  }

  .brand {
    display: inline-block;
    text-decoration: none;
    color: #ffffff;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.015em;
    margin-bottom: 0.875rem;
  }

  .brand:hover {
    opacity: 0.85;
  }

  .tag {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #94a3b8;
    max-width: 34ch;
  }

  .site-footer h3 {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .site-footer ul a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 160ms ease;
  }

  .site-footer ul a:hover {
    color: #ffffff;
  }

  .count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.4375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--primary, #0d6e6e);
    background: color-mix(in srgb, var(--primary, #0d6e6e) 22%, transparent);
    border-radius: 999px;
    font-variant-numeric: tabular-nums;
  }

  .bottom {
    padding-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    font-size: 0.8125rem;
    color: #94a3b8;
  }

  .bottom p {
    margin: 0;
  }

  .bottom .muted {
    color: #64748b;
  }

  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .about {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 420px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .container {
      padding: 2.5rem 1rem 1.25rem;
    }
  }

  @media print {
    .site-footer {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer ul a {
      transition: none;
    }
  }
</style>
