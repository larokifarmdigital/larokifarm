---
import type { GrupoEdad } from '@/lib/sanity';
import TablaCalendario from './TablaCalendario.astro';

interface Props {
  grupo: GrupoEdad;
}

const { grupo } = Astro.props;

const titulos: Record<GrupoEdad['nombre'], string> = {
  lactantes: 'Lactantes',
  infancia: 'Infancia',
  adolescencia: 'Adolescencia',
  adultos: 'Adultos',
  embarazadas: 'Embarazadas',
  mayores: 'Mayores (65+)',
};

const titulo = titulos[grupo.nombre] ?? grupo.nombre;
const entradas = grupo.entradas ?? [];
---

<section id={grupo.nombre}>
  <h2>{titulo}{grupo.descripcion && <span class="muted"> · {grupo.descripcion}</span>}</h2>
  {entradas.length === 0 ? (
    <p class="muted">Sin vacunas configuradas para este grupo.</p>
  ) : (
    <TablaCalendario entradas={entradas} />
  )}
</section>
