---
import {
  LOCALE_DEFECTO,
  LOCALES_DISPONIBLES,
  rutaConLocale,
  t,
  type Locale,
} from '@/lib/i18n';

interface Props {
  rutaActual?: string;
  lang?: Locale;
}

const { rutaActual = '/', lang = LOCALE_DEFECTO } = Astro.props;

const navItems: { ruta: string; clave: string }[] = [
  { ruta: '/', clave: 'nav.calendarios' },
  { ruta: '/fuentes', clave: 'nav.fuentes' },
  { ruta: '/farmacias', clave: 'nav.farmacias' },
];

const esActivo = (ruta: string) =>
  ruta === '/' ? rutaActual === '/' : rutaActual.startsWith(ruta);

const homeUrl = rutaConLocale('/', lang);
---

<header class="site-header">
  <div class="container">
    <a href={homeUrl} class="brand" aria-label={`${t('brand', lang)} · ${t('nav.calendarios', lang)}`}>
      {t('brand', lang)}
    </a>

    <nav aria-label={t('nav.aria', lang)} class="site-nav">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={rutaConLocale(item.ruta, lang)}
              class="site-link"
              aria-current={esActivo(item.ruta) ? 'page' : undefined}
            >
              {t(item.clave, lang)}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="lang-switcher" aria-label={t('idioma.selector', lang)}>
      {LOCALES_DISPONIBLES.map((codigo) => (
        <a
          href={rutaConLocale(rutaActual, codigo)}
          class:list={['lang-link', codigo === lang && 'active']}
          aria-current={codigo === lang ? 'true' : undefined}
        >
          {codigo.toUpperCase()}
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: #ffffff;
    box-shadow:
      0 1px 0 0 #e2e8f0,
      0 1px 3px -1px rgb(15 23 42 / 0.04);
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.25rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* Brand */
  .brand {
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.015em;
    color: var(--primary, #0d6e6e);
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand:hover {
    opacity: 0.85;
  }

  /* Nav (pill style) */
  .site-nav {
    flex: 1;
  }

  .site-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  .site-link {
    display: inline-block;
    padding: 0.4375rem 0.875rem;
    border-radius: 0.5rem;
    color: #475569;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition:
      color 160ms ease,
      background-color 160ms ease;
  }

  .site-link:hover {
    color: #0f172a;
    background: #f1f5f9;
  }

  .site-link[aria-current='page'] {
    color: var(--primary, #0d6e6e);
    background: color-mix(in srgb, var(--primary, #0d6e6e) 10%, transparent);
  }

  /* Language switcher */
  .lang-switcher {
    display: flex;
    gap: 0.125rem;
    flex-shrink: 0;
  }

  .lang-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #94a3b8;
    text-decoration: none;
    border-radius: 0.375rem;
    transition:
      color 160ms ease,
      background-color 160ms ease;
  }

  .lang-link:hover {
    color: #0f172a;
    background: #f1f5f9;
  }

  .lang-link.active {
    color: var(--primary, #0d6e6e);
    background: color-mix(in srgb, var(--primary, #0d6e6e) 10%, transparent);
  }

  /* Responsive */
  @media (max-width: 760px) {
    .container {
      height: auto;
      flex-wrap: wrap;
      padding: 0.625rem 1rem;
      gap: 0.5rem 1rem;
    }
    .site-nav {
      order: 3;
      flex-basis: 100%;
      overflow-x: auto;
      scrollbar-width: none;
      margin: 0 -1rem;
      padding: 0 1rem 0.25rem;
    }
    .site-nav::-webkit-scrollbar {
      display: none;
    }
    .site-nav ul {
      gap: 0.25rem;
      flex-wrap: nowrap;
      width: max-content;
    }
    .site-link {
      font-size: 0.875rem;
      padding: 0.375rem 0.75rem;
    }
  }

  @media print {
    .site-header {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-link,
    .lang-link {
      transition: none;
    }
  }
</style>
