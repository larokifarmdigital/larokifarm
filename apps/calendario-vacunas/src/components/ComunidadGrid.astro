---
import type { ComunidadResumen } from '@/lib/sanity';

interface Props {
  comunidades: ComunidadResumen[];
}

const { comunidades } = Astro.props;

const estatales = comunidades.filter((c) => c.tipo === 'comun-estatal');
const autonomias = comunidades.filter((c) => c.tipo !== 'comun-estatal');
---

{estatales.length > 0 && (
  <section>
    <h2>Calendario común estatal</h2>
    <ul class="grid">
      {estatales.map((c) => (
        <li>
          <a href={`/${c.slug}`}>
            <strong>{c.nombre}</strong>
            {c.vigencia && <span class="muted"> · {c.vigencia}</span>}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<section>
  <h2>Comunidades y ciudades autónomas</h2>
  <ul class="grid">
    {autonomias.map((c) => (
      <li>
        <a href={`/${c.slug}`}>
          <strong>{c.nombre}</strong>
          {c.vigencia && <span class="muted"> · {c.vigencia}</span>}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .grid li a {
    display: block;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-fg);
    transition: border-color 0.15s, transform 0.15s;
  }

  .grid li a:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
</style>
