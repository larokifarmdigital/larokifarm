---
import {
  CalendarioVacunas,
  listarComunidades,
  obtenerComunidad,
  t,
} from '@larokifarm/calendario-vacunas';

export async function getStaticPaths() {
  const comunidades = await listarComunidades();
  return comunidades.map((c) => ({ params: { comunidad: c.slug } }));
}

const { comunidad: slug } = Astro.params;
const comunidad = await obtenerComunidad(slug!);

if (!comunidad) {
  return Astro.redirect('/404');
}

const lang = 'es';
const titulo = `${t('detail.titleBase', lang)} · ${comunidad.nombre}${
  comunidad.vigencia ? ` ${comunidad.vigencia}` : ''
}`;
const descripcion = t('detail.descriptionTemplate', lang, {
  comunidad: `${comunidad.nombre}${comunidad.vigencia ? ` (${comunidad.vigencia})` : ''}`,
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalGuideline',
  name: titulo,
  guidelineSubject: {
    '@type': 'MedicalCondition',
    name: 'Vacunación',
  },
  evidenceOrigin: comunidad.fuenteOficial,
  inLanguage: lang,
  about: comunidad.nombre,
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={`/${slug}`} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <main>
      <CalendarioVacunas comunidad={comunidad} lang={lang} backHref="/" />
    </main>

    <style is:global>
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        line-height: 1.5;
      }
      main {
        max-width: 64rem;
        margin: 0 auto;
        padding: 1.5rem 1rem 4rem;
      }
      @media print {
        main {
          max-width: 100%;
          padding: 0;
        }
      }
    </style>
  </body>
</html>
