---
import BaseLayout from '@/layouts/BaseLayout.astro';

const titulo = 'Calendario no encontrado';
---

<BaseLayout titulo={titulo} rutaActual="/404">
  <div class="page-container">
    <h1>{titulo}</h1>
    <p>No hemos podido encontrar ese calendario.</p>
    <p><a href="/">Ver todos los calendarios</a></p>
  </div>
</BaseLayout>
