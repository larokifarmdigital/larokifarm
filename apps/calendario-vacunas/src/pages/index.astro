---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  IndiceComunidades,
  listarComunidades,
  t,
} from '@larokifarm/calendario-vacunas';

const lang = 'es';
const comunidades = await listarComunidades();
const titulo = t('index.title', lang);
const descripcion = t('index.description', lang);
---

<BaseLayout titulo={titulo} descripcion={descripcion} rutaActual="/">
  <div class="page-container">
    <IndiceComunidades comunidades={comunidades} lang={lang} basePath="" />
  </div>
</BaseLayout>
