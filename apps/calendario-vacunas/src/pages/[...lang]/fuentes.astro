---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  listarFuentesOficiales,
  type FuenteCategoria,
  type FuenteOficial,
} from '@larokifarm/calendario-vacunas';
import {
  LOCALE_DEFECTO,
  LOCALES_DISPONIBLES,
  rutaConLocale,
  t,
  type Locale,
} from '@/lib/i18n';

export async function getStaticPaths() {
  return LOCALES_DISPONIBLES.map((c) => ({
    params: { lang: c === LOCALE_DEFECTO ? undefined : c },
    props: { lang: c },
  }));
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const fuentes = await listarFuentesOficiales(lang);

const CATEGORIAS: { clave: FuenteCategoria; titulo: string; desc: string }[] = [
  {
    clave: 'estatal',
    titulo: t('fuentes.categorias.estatal', lang),
    desc: t('fuentes.categorias.estatalDesc', lang),
  },
  {
    clave: 'autonomica',
    titulo: t('fuentes.categorias.autonomica', lang),
    desc: t('fuentes.categorias.autonomicaDesc', lang),
  },
  {
    clave: 'sociedad',
    titulo: t('fuentes.categorias.sociedad', lang),
    desc: t('fuentes.categorias.sociedadDesc', lang),
  },
  {
    clave: 'internacional',
    titulo: t('fuentes.categorias.internacional', lang),
    desc: t('fuentes.categorias.internacionalDesc', lang),
  },
];

const porCategoria = new Map<FuenteCategoria, FuenteOficial[]>();
for (const f of fuentes) {
  const arr = porCategoria.get(f.categoria) ?? [];
  arr.push(f);
  porCategoria.set(f.categoria, arr);
}

const titulo = t('fuentes.titulo', lang);
const descripcion = t('fuentes.descripcion', lang);
const rutaActual = '/fuentes';

const hostname = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
};
---

<BaseLayout
  titulo={`${titulo} · ${t('brand', lang)}`}
  descripcion={descripcion}
  canonical={rutaConLocale(rutaActual, lang)}
  rutaActual={rutaActual}
  lang={lang}
>
  <div class="page-container">
    <header class="hero">
      <h1>{titulo}</h1>
      <p class="lead">{descripcion}</p>
    </header>

    {fuentes.length === 0 ? (
      <p class="empty">{t('fuentes.vacio', lang)}</p>
    ) : (
      CATEGORIAS.map(({ clave, titulo: tCat, desc }) => {
        const items = porCategoria.get(clave) ?? [];
        if (items.length === 0) return null;
        return (
          <section class="cat-section">
            <header class="cat-head">
              <h2>{tCat}</h2>
              <span class="count">{items.length}</span>
            </header>
            <p class="cat-desc">{desc}</p>
            <ul class="fuente-list">
              {items.map((f) => (
                <li class="fuente">
                  <a href={f.url} target="_blank" rel="noopener noreferrer">
                    <div class="fuente-meta">
                      {f.comunidadNombre && (
                        <span class="ccaa">{f.comunidadNombre}</span>
                      )}
                      <h3>{f.nombre}</h3>
                      {f.descripcion && <p>{f.descripcion}</p>}
                      <span class="host">{hostname(f.url)}</span>
                    </div>
                    <span class="arrow" aria-hidden="true">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })
    )}
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 56rem;
  }

  .hero {
    margin-bottom: 2.5rem;
  }

  .hero h1 {
    font-size: clamp(1.875rem, 2.5vw + 1rem, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    color: #0f172a;
  }

  .lead {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #475569;
    max-width: 60ch;
    margin: 0;
  }

  .empty {
    padding: 2.5rem;
    text-align: center;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 0.75rem;
    color: #64748b;
  }

  .cat-section {
    margin-bottom: 2.5rem;
  }

  .cat-head {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin: 0 0 0.375rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .cat-head h2 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0;
    color: #0f172a;
  }

  .count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #64748b;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
  }

  .cat-desc {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0 0 1rem;
  }

  .fuente-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.625rem;
  }

  .fuente a {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.125rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 0.625rem;
    text-decoration: none;
    color: #0f172a;
    transition:
      border-color 180ms ease,
      box-shadow 220ms ease,
      transform 180ms ease;
  }

  .fuente a:hover {
    border-color: var(--primary, #0d6e6e);
    box-shadow: 0 4px 14px -4px rgb(15 23 42 / 0.08);
    transform: translateY(-1px);
  }

  .fuente-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .ccaa {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary, #0d6e6e);
  }

  .fuente h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.01em;
  }

  .fuente p {
    margin: 0;
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.5;
  }

  .host {
    font-size: 0.75rem;
    color: #94a3b8;
    margin-top: 0.25rem;
  }

  .arrow {
    flex-shrink: 0;
    font-size: 1rem;
    color: #cbd5e1;
    transition:
      color 180ms ease,
      transform 220ms ease;
  }

  .fuente a:hover .arrow {
    color: var(--primary, #0d6e6e);
    transform: translate(2px, -2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .fuente a,
    .arrow {
      transition: none;
    }
    .fuente a:hover {
      transform: none;
    }
  }
</style>
