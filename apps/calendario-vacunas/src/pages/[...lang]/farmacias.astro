---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { listarFarmaciasPartner } from '@larokifarm/calendario-vacunas';
import {
  LOCALE_DEFECTO,
  LOCALES_DISPONIBLES,
  rutaConLocale,
  t,
  type Locale,
} from '@/lib/i18n';

export async function getStaticPaths() {
  return LOCALES_DISPONIBLES.map((c) => ({
    params: { lang: c === LOCALE_DEFECTO ? undefined : c },
    props: { lang: c },
  }));
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const partners = await listarFarmaciasPartner();

const titulo = t('farmacias.titulo', lang);
const descripcion = t('farmacias.descripcion', lang);
const rutaActual = '/farmacias';

const hostname = (url?: string) => {
  if (!url) return '';
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
};
---

<BaseLayout
  titulo={`${titulo} · ${t('brand', lang)}`}
  descripcion={descripcion}
  canonical={rutaConLocale(rutaActual, lang)}
  rutaActual={rutaActual}
  lang={lang}
>
  <div class="page-container">
    <header class="hero">
      <h1>{titulo}</h1>
      <p class="lead">{descripcion}</p>
    </header>

    {partners.length === 0 ? (
      <p class="empty">{t('farmacias.vacio', lang)}</p>
    ) : (
      <ul class="partner-grid">
        {partners.map((p) => {
          const host = hostname(p.url);
          const Inner = (
            <>
              <div class="partner-logo">
                {p.logoUrl ? (
                  <img
                    src={`${p.logoUrl}?auto=format&q=80&w=240`}
                    alt={p.nombre}
                    width="180"
                    height="80"
                    loading="lazy"
                  />
                ) : (
                  <span class="logo-fallback" aria-hidden="true">
                    {p.nombre.slice(0, 1).toUpperCase()}
                  </span>
                )}
              </div>
              <div class="partner-body">
                <h2>{p.nombre}</h2>
                {p.ciudad && <p class="city">{p.ciudad}</p>}
                {p.descripcionCorta && <p class="desc">{p.descripcionCorta}</p>}
                {host && <span class="host">{host} ↗</span>}
              </div>
            </>
          );
          return (
            <li>
              {p.url ? (
                <a href={p.url} target="_blank" rel="noopener noreferrer">
                  {Inner}
                </a>
              ) : (
                <div class="static">{Inner}</div>
              )}
            </li>
          );
        })}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 64rem;
  }

  .hero {
    margin-bottom: 2.5rem;
  }

  .hero h1 {
    font-size: clamp(1.875rem, 2.5vw + 1rem, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    color: #0f172a;
  }

  .lead {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #475569;
    max-width: 60ch;
    margin: 0;
  }

  .empty {
    padding: 2.5rem;
    text-align: center;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 0.75rem;
    color: #64748b;
  }

  .partner-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .partner-grid li > * {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 0.875rem;
    overflow: hidden;
    text-decoration: none;
    color: #0f172a;
    transition:
      border-color 180ms ease,
      box-shadow 220ms ease,
      transform 180ms ease;
  }

  .partner-grid li a:hover {
    border-color: var(--primary, #0d6e6e);
    box-shadow: 0 10px 30px -10px rgb(15 23 42 / 0.15);
    transform: translateY(-2px);
  }

  .partner-logo {
    height: 7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8fafc;
    border-bottom: 1px solid #f1f5f9;
    padding: 1rem;
  }

  .partner-logo img {
    max-width: 100%;
    max-height: 4rem;
    object-fit: contain;
  }

  .logo-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary, #0d6e6e) 12%, white);
    color: var(--primary, #0d6e6e);
    font-size: 1.25rem;
    font-weight: 800;
  }

  .partner-body {
    padding: 1rem 1.125rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .partner-body h2 {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
    color: #0f172a;
  }

  .city {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #64748b;
  }

  .desc {
    margin: 0.375rem 0 0;
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.55;
  }

  .host {
    margin-top: auto;
    padding-top: 0.625rem;
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .partner-grid li a:hover .host {
    color: var(--primary, #0d6e6e);
  }

  @media (prefers-reduced-motion: reduce) {
    .partner-grid li > * {
      transition: none;
    }
    .partner-grid li a:hover {
      transform: none;
    }
  }
</style>
