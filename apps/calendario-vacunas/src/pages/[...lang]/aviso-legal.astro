---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { obtenerPaginaLegal } from '@larokifarm/calendario-vacunas';
import { renderPortableText } from '@/lib/portableText.ts';
import {
  LOCALE_DEFECTO,
  LOCALES_DISPONIBLES,
  rutaConLocale,
  t,
  type Locale,
} from '@/lib/i18n';

export async function getStaticPaths() {
  return LOCALES_DISPONIBLES.map((c) => ({
    params: { lang: c === LOCALE_DEFECTO ? undefined : c },
    props: { lang: c },
  }));
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const pagina = await obtenerPaginaLegal('aviso-legal');

const tituloDefault = t('legal.tituloAvisoLegal', lang);
const titulo = pagina?.titulo ?? tituloDefault;
const descripcion = t('legal.descAvisoLegal', lang);
const html = pagina ? renderPortableText(pagina.contenido) : '';

const localeMap: Record<Locale, string> = { es: 'es-ES', en: 'en-US', ca: 'ca-ES' };
const actualizado = pagina?.actualizadoEl
  ? new Date(pagina.actualizadoEl).toLocaleDateString(localeMap[lang], {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const rutaActual = '/aviso-legal';
---

<BaseLayout
  titulo={`${titulo} · ${t('brand', lang)}`}
  descripcion={descripcion}
  canonical={rutaConLocale(rutaActual, lang)}
  rutaActual={rutaActual}
  lang={lang}
>
  <div class="page-container">
    <article class="prose">
      <header class="prose-head">
        <h1>{titulo}</h1>
        {actualizado && (
          <p class="updated">{t('legal.actualizado', lang)}: {actualizado}</p>
        )}
      </header>

      {pagina ? (
        <div set:html={html} />
      ) : (
        <p class="empty">
          {t('legal.vacioPrefijo', lang)} <code>paginaLegal</code>{' '}
          {t('legal.vacioSlug', lang)} <code>aviso-legal</code>.
        </p>
      )}
    </article>
  </div>
</BaseLayout>

<style is:global>
  .prose {
    max-width: 42rem;
    margin: 0 auto;
    color: #1e293b;
    line-height: 1.7;
  }

  .prose-head {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .prose-head h1 {
    font-size: clamp(1.875rem, 2.5vw + 1rem, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
    color: #0f172a;
  }

  .prose-head .updated {
    margin: 0;
    font-size: 0.875rem;
    color: #64748b;
  }

  .prose h2 {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 2.25rem 0 0.75rem;
    color: #0f172a;
  }

  .prose h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 1.75rem 0 0.5rem;
    color: #0f172a;
  }

  .prose h4 {
    font-size: 1rem;
    font-weight: 700;
    margin: 1.25rem 0 0.5rem;
    color: #0f172a;
  }

  .prose p {
    margin: 0 0 1rem;
  }

  .prose a {
    color: var(--primary, #0d6e6e);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .prose a:hover {
    text-decoration-thickness: 2px;
  }

  .prose ul,
  .prose ol {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose li {
    margin: 0 0 0.375rem;
  }

  .prose blockquote {
    margin: 1.25rem 0;
    padding: 0.75rem 1rem;
    border-left: 3px solid var(--primary, #0d6e6e);
    background: #f8fafc;
    color: #475569;
    font-style: italic;
  }

  .prose code {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    color: #0f172a;
  }

  .prose .empty {
    padding: 1.5rem;
    background: #fff7ed;
    border: 1px solid #fdba74;
    border-radius: 0.5rem;
    color: #9a3412;
  }

  .prose .empty code {
    background: #fed7aa;
    color: #7c2d12;
  }
</style>
